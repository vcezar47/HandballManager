<UserControl x:Class="HandballManager.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"   Value="#16213E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="24"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"      Value="#E94560"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="28,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C73652"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#333355"/>
                                <Setter Property="Foreground" Value="#666688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
            <StackPanel Width="1000">

                <!-- Page title -->
                <TextBlock Text="DASHBOARD" FontSize="11" FontWeight="ExtraBold"
                           Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
                <TextBlock Text="Season Overview" FontSize="36" FontWeight="Black"
                           Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,32"/>

                <!-- Next Match Card -->
                <Border CornerRadius="20" Margin="0,0,0,32" Padding="40,35">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A2238" Offset="0"/>
                            <GradientStop Color="#16213E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.3" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="UPCOMING FIXTURE" FontSize="10" FontWeight="ExtraBold"
                                   Foreground="#E94560" FontFamily="Segoe UI"
                                   Margin="0,0,0,12" HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding NextMatchInfo}" FontSize="28"
                                   FontWeight="Black" Foreground="White" FontFamily="Segoe UI"
                                   Margin="0,0,0,10" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Border Background="#162A46" CornerRadius="14" Padding="12,6" Margin="0,0,10,0" BorderBrush="#1E3A5F" BorderThickness="1">
                                <TextBlock Text="{Binding CurrentDateText, StringFormat={}Today: {0}}" Foreground="#A0A8C0" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <Border Background="#162A46" CornerRadius="14" Padding="12,6" BorderBrush="#1E3A5F" BorderThickness="1">
                                <TextBlock Text="{Binding NextMatchDateText, StringFormat={}Matchday: {0}}" Foreground="#38BDF8" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding NextCupMatchInfo}" FontSize="13" Foreground="#FFD700" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCupMatchday}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="ADVANCE DAY" Width="170" Height="50"
                                    Foreground="White" FontSize="13" FontWeight="Black"
                                    Background="#334155"
                                    Command="{Binding AdvanceDayCommand}"
                                    IsEnabled="{Binding CanAdvanceDay}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" CornerRadius="25" Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="SIMULATE MATCHDAY" Width="240" Height="50" Margin="14,0,0,0"
                                    Foreground="White" FontSize="13" FontWeight="Black"
                                    Command="{Binding SimulateMatchCommand}"
                                    IsEnabled="{Binding CanSimulateMatch}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" CornerRadius="25">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#E94560" Offset="0"/>
                                                                <GradientStop Color="#C73652" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Background">
                                                                <Setter.Value>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#FF536E" Offset="0"/>
                                                                        <GradientStop Color="#E94560" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- DEV TOOL: Fast-forward to end of season for balancing -->
                            <!--<Button Content="&#x26A1; SIM TO END" Width="160" Height="50" Margin="14,0,0,0"
                                    Foreground="#1A1A2E" FontSize="13" FontWeight="Black"
                                    Command="{Binding SimulateToEndOfSeasonCommand}"
                                    IsEnabled="{Binding CanSimulateToEndOfSeason}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" CornerRadius="25">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#F59E0B" Offset="0"/>
                                                                <GradientStop Color="#D97706" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Background">
                                                                <Setter.Value>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#FBBF24" Offset="0"/>
                                                                        <GradientStop Color="#F59E0B" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>-->
                            
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="20,0,0,0">
                                <TextBlock Text="&#x231B;" Foreground="#A0A8C0" VerticalAlignment="Center" FontSize="18"/>
                                <TextBlock Text="Calculating..." Foreground="#A0A8C0" FontSize="14"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Season Over Banner -->
                <Border CornerRadius="20" Padding="30" Margin="0,0,0,32"
                        Visibility="{Binding IsSeasonOver, Converter={StaticResource BoolToVis}}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E94560" Offset="0"/>
                            <GradientStop Color="#C73652" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="SEASON COMPLETED" FontSize="11" FontWeight="ExtraBold"
                                   Foreground="White" Opacity="0.8" FontFamily="Segoe UI"
                                   Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="The Liga Florilor season has come to an end." FontSize="24" FontWeight="Black"
                                   Foreground="White" FontFamily="Segoe UI" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                        <Button Content="BEGIN NEW SEASON" Style="{StaticResource ActionButton}"
                                Background="White" Foreground="#E94560" HorizontalAlignment="Center"
                                Command="{Binding BeginNewSeasonCommand}"
                                IsEnabled="{Binding CanBeginNewSeason}"/>
                    </StackPanel>
                </Border>

                <!-- Matchweek Results Browser -->
                <Border CornerRadius="20" Background="#16213E" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Navigation Header -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="◀" 
                                    Command="{Binding ChangeMatchweekCommand}" CommandParameter="-1"
                                    Background="Transparent" Foreground="#666688" FontSize="20" BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MatchweekDateText}"
                                           FontSize="14" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="▶" 
                                    Command="{Binding ChangeMatchweekCommand}" CommandParameter="1"
                                    Background="Transparent" Foreground="#666688" FontSize="20" BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding MatchweekResults}" HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ViewMatchDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1A2238" CornerRadius="12" Padding="25,15" Margin="0,0,0,10" x:Name="MatchBorder">
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="White" Opacity="0.03"/>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Column="0" Text="{Binding HomeTeamName}" 
                                                                   Foreground="White" FontSize="16" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                                                        
                                                        <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,6" HorizontalAlignment="Center">
                                                            <TextBlock Foreground="#E94560" FontSize="18" FontWeight="Black" TextAlignment="Center">
                                                                <Run Text="{Binding HomeGoals}"/>
                                                                <Run Text=" : "/>
                                                                <Run Text="{Binding AwayGoals}"/>
                                                            </TextBlock>
                                                        </Border>
                                                        
                                                        <TextBlock Grid.Column="2" Text="{Binding AwayTeamName}" 
                                                                   Foreground="White" FontSize="16" FontWeight="Bold" TextAlignment="Left" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CupRound, StringFormat='{}&#x1F3C6; {0}'}" Foreground="#FFD700" FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center" Margin="0,8,0,0"
                                                               Visibility="{Binding IsCupMatch, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="MatchBorder" Property="Background" Value="#252D45"/>
                                                        <Setter TargetName="MatchBorder" Property="BorderBrush" Value="#E94560"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Fixtures not yet generated or played."
                                   Foreground="#555577" FontFamily="Segoe UI" FontSize="15"
                                   FontStyle="Italic" HorizontalAlignment="Center" Margin="0,30,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MatchweekResults.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
