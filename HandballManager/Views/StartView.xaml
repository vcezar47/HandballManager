<UserControl x:Class="HandballManager.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:HandballManager.Views"
             xmlns:converters="clr-namespace:HandballManager.Converters"
             Background="#1A1A2E">
    <UserControl.Resources>
        <converters:EqualityToVisibilityConverter x:Key="EqualityToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo/Header -->
        <StackPanel Grid.Row="0" Margin="0,40,0,30" TextOptions.TextRenderingMode="ClearType">
            <Image Source="/Assets/gamelogo/colorpng.png" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
            <TextBlock Text="HANDBALL" FontSize="32" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" FontFamily="Segoe UI"/>
            <TextBlock Text="MANAGER" FontSize="18" FontWeight="Bold" Foreground="#E94560"
                       HorizontalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <!-- Step 0: Manager Creation -->
            <ContentControl Visibility="{Binding CurrentStep, Converter={StaticResource EqualityToVis}, ConverterParameter=0, FallbackValue=Collapsed}">
                <views:ManagerCreationView DataContext="{Binding ManagerCreationVM}"/>
            </ContentControl>

            <!-- Step 1: League Selection -->
            <ContentControl Visibility="{Binding CurrentStep, Converter={StaticResource EqualityToVis}, ConverterParameter=1, FallbackValue=Collapsed}">
                <views:LeagueSelectionView />
            </ContentControl>

            <!-- Step 2: Team Selection -->
            <ContentControl Visibility="{Binding CurrentStep, Converter={StaticResource EqualityToVis}, ConverterParameter=2, FallbackValue=Collapsed}">
                <views:TeamSelectionView Loaded="TeamSelectionView_Loaded"/>
            </ContentControl>
        </Grid>

        <!-- Footer spacing -->
        <Border Grid.Row="2" Height="60"/>
    </Grid>
</UserControl>
