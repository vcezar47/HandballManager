<UserControl x:Class="HandballManager.Views.CupDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Tab style matching TransfersView -->
        <Style x:Key="CupTabItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                            <TextBlock x:Name="TabText" Text="{TemplateBinding Content}" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group table header style -->
        <Style x:Key="GroupHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#A0A8C0"/>
            <Setter Property="FontWeight"      Value="ExtraBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="6,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="#2A2A4A"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GroupRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1E1E3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2238"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding"         Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1200" HorizontalAlignment="Center" Margin="40,30">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="{Binding CupDisplayName}" FontSize="11" FontWeight="ExtraBold"
                           Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
                <Button Command="{Binding ViewCupHistoryCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" HorizontalAlignment="Left" x:Name="HistoryBtn">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding DataContext.CupLogoPath, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="40" Height="40" Margin="0,0,16,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding DataContext.CupDisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="36" FontWeight="Black"
                                           Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center" x:Name="HeaderText"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="#E94560"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Tab Strip -->
                <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="8,8,8,0" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="GROUP PHASE" Style="{StaticResource CupTabItem}"
                                Command="{Binding SelectTabCommand}" CommandParameter="GroupPhase">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="20,10" Margin="0,0,4,0">
                                        <TextBlock x:Name="TabText" Text="GROUP PHASE" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="GroupPhase">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                            <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                            <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="KNOCKOUT PHASE" Style="{StaticResource CupTabItem}"
                                Command="{Binding SelectTabCommand}" CommandParameter="KnockoutPhase">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="20,10" Margin="0,0,4,0">
                                        <TextBlock x:Name="TabText" Text="KNOCKOUT PHASE" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="KnockoutPhase">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                            <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                            <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- GROUP PHASE CONTENT -->
                <StackPanel Margin="0,16,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="GroupPhase">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- 2x2 Grid of Groups -->
                    <ItemsControl ItemsSource="{Binding AllGroups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="16" Background="#16213E" Padding="16" Margin="6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock FontSize="15" FontWeight="Black" Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10">
                                            <Run Text="GROUP "/>
                                            <Run Text="{Binding GroupName, Mode=OneWay}"/>
                                        </TextBlock>

                                        <DataGrid ItemsSource="{Binding Entries}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserReorderColumns="False"
                                                  GridLinesVisibility="None"
                                                  Background="Transparent"
                                                  RowBackground="Transparent"
                                                  BorderThickness="0"
                                                  FontFamily="Segoe UI"
                                                  FontSize="12"
                                                  Foreground="White"
                                                  ColumnHeaderHeight="32"
                                                  RowHeight="34"
                                                  HeadersVisibility="Column"
                                                  ColumnHeaderStyle="{StaticResource GroupHeaderStyle}"
                                                  RowStyle="{StaticResource GroupRowStyle}"
                                                  CellStyle="{StaticResource GroupCellStyle}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="30">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="#666688"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTemplateColumn Width="12">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Width="3" Height="18" CornerRadius="1.5" HorizontalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Rank}" Value="1">
                                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Rank}" Value="2">
                                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="CLUB" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                                <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="16" Height="16" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="11"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="30">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="W" Binding="{Binding Won}" Width="30">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="D" Binding="{Binding Drawn}" Width="30">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="L" Binding="{Binding Lost}" Width="30">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Foreground" Value="#F87171"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="35">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="40">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="FontWeight" Value="Black"/>
                                                            <Setter Property="Foreground" Value="#E94560"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- KNOCKOUT PHASE CONTENT -->
                <StackPanel Margin="0,16,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="KnockoutPhase">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border CornerRadius="20" Background="#16213E" Padding="30" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Quarter-Finals (HIDDEN FOR HUNGARY) -->
                            <StackPanel Visibility="{Binding IsHungarianCup, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                <TextBlock Text="QUARTER-FINALS" FontSize="13" FontWeight="ExtraBold"
                                           Foreground="#E94560" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                                <ItemsControl ItemsSource="{Binding QuarterFinals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A2238" CornerRadius="12" Padding="20,12" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="White" Opacity="0.05"/>
                                                </Border.BorderBrush>
                                                <Border.BorderThickness>1</Border.BorderThickness>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="10,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding ScoreDisplay}" Foreground="#E94560" FontSize="16" FontWeight="Black" TextAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Quarter-finals will be determined after the group stage."
                                           Foreground="#555577" FontStyle="Italic" FontFamily="Segoe UI" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QuarterFinals.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- Semi-Finals -->
                            <TextBlock Text="SEMI-FINALS" FontSize="13" FontWeight="ExtraBold"
                                       Foreground="#E94560" FontFamily="Segoe UI" Margin="0,28,0,16"/>
                            <ItemsControl ItemsSource="{Binding SemiFinals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="MatchBorder" Background="#1A2238" CornerRadius="12" Padding="24,16" Margin="0,0,0,8"
                                                BorderBrush="#252D45" BorderThickness="1" HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#252D45"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#E94560"/>
                                                            <Setter Property="Background" Value="#1E293B"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="10,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding ScoreDisplay}" Foreground="#E94560" FontSize="16" FontWeight="Black" TextAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding VenueName}" Foreground="#666688" FontSize="11" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Semi-finals will be determined after the quarter-finals."
                                       Foreground="#555577" FontStyle="Italic" FontFamily="Segoe UI" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SemiFinals.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- 3rd Place Match -->
                            <TextBlock Text="3RD PLACE MATCH" FontSize="13" FontWeight="ExtraBold"
                                       Foreground="#A0A8C0" FontFamily="Segoe UI" Margin="0,28,0,16"/>
                            <Border Background="#1A2238" CornerRadius="12" Padding="20,12" Margin="0,0,0,8" 
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding ThirdPlaceMatch, Converter={StaticResource NullToVis}}">
                                <Grid DataContext="{Binding ThirdPlaceMatch}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                         <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="10,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                     </StackPanel>
                                     <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,4" HorizontalAlignment="Center">
                                         <TextBlock Text="{Binding ScoreDisplay}" Foreground="#A0A8C0" FontSize="16" FontWeight="Black" TextAlignment="Center"/>
                                     </Border>
                                     <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                         <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                         <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Grid>
                             </Border>
                             <TextBlock Text="3rd place match will be determined after the semi-finals."
                                        Foreground="#555577" FontStyle="Italic" FontFamily="Segoe UI" Margin="0,4,0,0"
                                        Visibility="{Binding ThirdPlaceMatch, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                             </TextBlock>

                            <!-- FINAL -->
                            <TextBlock Text="&#x1F3C6;  FINAL" FontSize="16" FontWeight="ExtraBold"
                                       Foreground="#FFD700" FontFamily="Segoe UI" Margin="0,28,0,16"/>
                            <Border CornerRadius="16" Padding="24,16" Margin="0,0,0,8" 
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding FinalMatch, Converter={StaticResource NullToVis}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A2238" Offset="0"/>
                                        <GradientStop Color="#1E293B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FFD700" Opacity="0.3"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Grid DataContext="{Binding FinalMatch}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                         <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="32" Height="32" Margin="15,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                     </StackPanel>
                                     <Border Grid.Column="1" Background="#0F172A" CornerRadius="12" Padding="14,6" HorizontalAlignment="Center">
                                         <TextBlock Text="{Binding ScoreDisplay}" Foreground="#FFD700" FontSize="20" FontWeight="Black" TextAlignment="Center"/>
                                     </Border>
                                     <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                         <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="32" Height="32" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                         <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Grid>
                             </Border>
                             <TextBlock Text="The final will be determined after the semi-finals."
                                        Foreground="#555577" FontStyle="Italic" FontFamily="Segoe UI" Margin="0,4,0,0"
                                        Visibility="{Binding FinalMatch, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                             </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
