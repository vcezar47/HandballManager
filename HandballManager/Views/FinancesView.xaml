<UserControl x:Class="HandballManager.Views.FinancesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:HandballManager.ViewModels;assembly=HandballManager.Core"
             xmlns:conv="clr-namespace:HandballManager.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:FinancesViewModel}">
    
    <UserControl.Resources>
        <conv:AmountToColorConverter x:Key="AmountToColorConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="CLUB FINANCES" Foreground="White" FontSize="32" FontWeight="Black" Margin="0,0,0,30"/>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Dashboard Left Column -->
            <StackPanel Grid.Column="0" Margin="0,0,30,0">
                
                <!-- Current Budgets Overview -->
                <Border Background="#16213E" CornerRadius="12" Padding="25" Margin="0,0,0,25">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TRANSFER BUDGET" Foreground="#A0A8C0" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TransferBudget, StringFormat='€{0:N0}'}" Foreground="#4ECDC4" FontSize="36" FontWeight="Black"/>
                            <TextBlock Text="Available for permanent transfers" Foreground="#666688" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="WAGE BUDGET" Foreground="#A0A8C0" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding WageBudget, StringFormat='€{0:N0} / p.w.'}" Foreground="#E94560" FontSize="36" FontWeight="Black"/>
                            <TextBlock Text="Available for player contracts" Foreground="#666688" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Budget Adjustment Tool -->
                <Border Background="#16213E" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="ADJUST BUDGETS" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Text="Use the slider to shift funds between your Transfer Budget and Wage Budget." Foreground="#A0A8C0" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,25"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Image Source="/Assets/icons/left_arrow.png" Width="12" Height="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Move to Wage Budget" Foreground="#E94560" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Move to Transfer Budget" Foreground="#4ECDC4" FontSize="12" FontWeight="Bold"/>
                                <Image Source="/Assets/icons/right_arrow.png" Width="12" Height="12" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Slider Value="{Binding BudgetSliderValue}" Minimum="{Binding MinSliderValue}" Maximum="{Binding MaxSliderValue}" 
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,30" AutoToolTipPlacement="TopLeft"/>

                        <Button Content="CONFIRM CHANGES" Command="{Binding ConfirmBudgetsCommand}"
                                Width="200" Height="45" Background="#E94560" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Right">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C73652"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Column -->
            <StackPanel Grid.Column="1">
                <!-- Financial Summary -->
                <Border Background="#16213E" CornerRadius="12" Padding="25" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="FINANCIAL SUMMARY" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Total Club Balance" Foreground="#A0A8C0" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ClubBalance, StringFormat='€{0:N0}'}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    </StackPanel>
                </Border>

                <!-- Transactions -->
                <Border Background="#16213E" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="RECENT TRANSACTIONS" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Transactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2A2A4A" BorderThickness="0,0,0,1" Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                                    <TextBlock Text="{Binding Description}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Date, StringFormat='dd MMM yyyy'}" Foreground="#666688" FontSize="12" Margin="0,3,0,0"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='€{0:N0}'}" 
                                                           Foreground="{Binding Amount, Converter={StaticResource AmountToColorConverter}}" 
                                                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
