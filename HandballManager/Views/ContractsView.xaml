<UserControl x:Class="HandballManager.Views.ContractsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <!-- Re-declared locally so DataTemplates (which have no visual parent at parse time) can resolve it via StaticResource -->
        <conv:ContractUrgencyConverter x:Key="ContractUrgency"/>
    </UserControl.Resources>
    <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="CONTRACTS" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
            <TextBlock Text="Contract status" FontSize="36" FontWeight="Black" Foreground="White" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Table Container -->
        <Border Grid.Row="1" CornerRadius="20" Background="#16213E" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.2" ShadowDepth="10"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Contracts}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserReorderColumns="False" GridLinesVisibility="None"
                      Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                      FontFamily="Segoe UI" FontSize="14" Foreground="White"
                      ColumnHeaderHeight="45" RowHeight="48"
                      SelectionMode="Single" HeadersVisibility="Column"
                      MaxHeight="520"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeadersPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Width" Value="6"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Foreground"      Value="#A0A8C0"/>
                        <Setter Property="FontWeight"      Value="ExtraBold"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="Padding"         Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush"     Value="#2A2A4A"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#1E1E3A"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2238"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A3A6A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"           Value="15,0"/>
                        <Setter Property="BorderThickness"   Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding ShirtNumber}" Width="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="FontWeight"          Value="Black"/>
                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="PLAYER" Binding="{Binding PlayerName}" Width="*" MinWidth="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight"        Value="Bold"/>
                                <Setter Property="Foreground"        Value="White"/>
                                <Setter Property="Padding"           Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="POS" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#1E2A4A" CornerRadius="4" HorizontalAlignment="Center"
                                        Padding="8,3" Margin="0,4">
                                    <TextBlock Text="{Binding Position}" Foreground="#A0A8C0"
                                               FontWeight="Bold" FontSize="12" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="CONTRACT LEFT" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" HorizontalAlignment="Left" Padding="12,5" Margin="4,4"
                                        Background="{Binding ContractTimeLeft, Converter={StaticResource ContractUrgency}, ConverterParameter=bg}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⏱" FontSize="11" Margin="0,0,6,0" Opacity="0.8"
                                                   Foreground="{Binding ContractTimeLeft, Converter={StaticResource ContractUrgency}}"/>
                                        <TextBlock Text="{Binding ContractTimeLeft}" FontWeight="Bold" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{Binding ContractTimeLeft, Converter={StaticResource ContractUrgency}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
