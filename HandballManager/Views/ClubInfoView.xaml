<UserControl x:Class="HandballManager.Views.ClubInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HandballManager.ViewModels;assembly=HandballManager.Core"
             xmlns:views="clr-namespace:HandballManager.Views"
             xmlns:converters="clr-namespace:HandballManager.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ClubInfoViewModel}">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
        <converters:StadiumImagePathConverter x:Key="StadiumImagePathConverter"/>
        <converters:LevelToOpacityConverter x:Key="LevelToOpacityConverter"/>
        <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" 
                                Background="Transparent" 
                                CornerRadius="10,10,0,0"
                                Padding="20,12"
                                Margin="0,0,8,0"
                                Cursor="Hand">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="ExtraBold"
                                       Foreground="#8888AA"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Tab strip -->
                            <Border Grid.Row="0" Background="#0F172A" CornerRadius="12,12,0,0" Padding="12,12,12,0">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <!-- Content area -->
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid MaxWidth="1200" HorizontalAlignment="Center" Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="CLUB INFO" FontSize="11" FontWeight="ExtraBold"
                       Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
            <TextBlock Text="{Binding Team.Name}" FontSize="36" FontWeight="Black"
                       Foreground="White" FontFamily="Segoe UI"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <!-- GENERAL TAB -->
            <TabItem Header="GENERAL" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Visual Assets -->
                        <Grid Grid.Column="0" Margin="0,0,30,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Logo Card -->
                            <Border Grid.Row="0" Width="300" Height="300" Background="#16213E" CornerRadius="24" Padding="45" Margin="0,0,0,25">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="10" Color="Black"/>
                                </Border.Effect>
                                <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" 
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- Stadium Card -->
                            <Border Grid.Row="1" Width="300" Background="#16213E" CornerRadius="24" Padding="20" Margin="0,0,0,30">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="STADIUM" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560" Margin="0,0,0,15"/>
                                    
                                    <!-- Stadium Image -->
                                    <Border CornerRadius="16" ClipToBounds="True" Height="170" Margin="0,0,0,15" Background="#0F172A">
                                        <Image Source="{Binding Team.StadiumImage, Converter={StaticResource StadiumImagePathConverter}}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <TextBlock Text="{Binding Team.StadiumName}" Foreground="White" FontSize="18" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    
                                    <Border Background="#1A264F" CornerRadius="10" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="TOTAL CAPACITY" Foreground="#8888AA" FontSize="10" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Team.StadiumCapacity, StringFormat={}{0:N0}}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Details Box -->
                        <StackPanel Grid.Column="1">
                            <Border Background="#16213E" CornerRadius="20" Padding="30">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30" Opacity="0.1" ShadowDepth="5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="CLUB DESCRIPTION" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding Team.Description}" Foreground="White" FontSize="17" LineHeight="26" TextWrapping="Wrap" Margin="0,0,0,40" Opacity="0.9"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Row 1 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,30">
                                            <TextBlock Text="CITY" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Team.City}" Foreground="White" FontSize="20" FontWeight="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,30">
                                            <TextBlock Text="MANAGER" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Manager.Name}" Foreground="#E94560" FontSize="20" FontWeight="Black" Cursor="Hand">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToManagerDetailCommand}"/>
                                                </TextBlock.InputBindings>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Row 2 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,35">
                                            <TextBlock Text="BUDGET" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Team.Budget, StringFormat={}{0:N0} €}" Foreground="White" FontSize="20" FontWeight="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,35">
                                            <TextBlock Text="REPUTATION" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <Border Background="#1A264F" CornerRadius="8" Padding="12,6" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Team.ClubReputation}" Foreground="#E94560" FontSize="16" FontWeight="Black"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Row 3 -->
                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="NATION" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Team.Nation}" Foreground="White" FontSize="20" FontWeight="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="FOUNDED" FontSize="11" FontWeight="ExtraBold" Foreground="#8888AA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Team.FoundedYear}" Foreground="White" FontSize="20" FontWeight="Black"/>
                                        </StackPanel>

                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Financial Mini-cards -->
                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#16213E" CornerRadius="15" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="CLUB BALANCE" FontSize="9" FontWeight="Bold" Foreground="#666688" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Team.ClubBalance, StringFormat={}{0:N0} €}" Foreground="#38BDF8" FontSize="18" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#16213E" CornerRadius="15" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="TRANSFER BUDGET" FontSize="9" FontWeight="Bold" Foreground="#666688" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Team.TransferBudget, StringFormat={}{0:N0} €}" Foreground="#E94560" FontSize="18" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- FACILITIES TAB -->
            <TabItem Header="FACILITIES" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Training Facilities -->
                        <Border Grid.Column="0" Background="#16213E" CornerRadius="20" Padding="30">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" Opacity="0.1" ShadowDepth="5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Image Grid.Row="0" Source="/Assets/icons/training.png" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,15" RenderOptions.BitmapScalingMode="HighQuality"/>

                                <TextBlock Grid.Row="1" Text="TRAINING FACILITIES" FontSize="18" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                <Border Grid.Row="2" Background="{Binding TrainingFacilityColour}" CornerRadius="8" Padding="12,6" HorizontalAlignment="Center" Margin="0,0,0,15">
                                    <TextBlock Text="{Binding TrainingFacilityLabel}" Foreground="White" FontSize="14" FontWeight="ExtraBold"/>
                                </Border>

                                <TextBlock Grid.Row="3" Text="{Binding TrainingFacilityDescription}" Foreground="#8888AA" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Height="65" Margin="0,0,0,15"/>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=0}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=1}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=2}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=3}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=4}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=5}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding TrainingFacilityColour}" Opacity="{Binding TrainingFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=6}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Visibility="{Binding IsPlayerTeam, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Separator Background="#1A264F" Height="1" Margin="0,0,0,25"/>

                                <Grid>
                                    <!-- Max Level -->
                                    <StackPanel Visibility="{Binding TrainingFacilityLevel, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=6}" HorizontalAlignment="Center">
                                        <TextBlock Text="MAXIMUM LEVEL REACHED" Foreground="#84CC16" FontSize="16" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10"/>
                                    </StackPanel>

                                    <!-- Under max level -->
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrainingFacilityLevel}" Value="6">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!-- If Upgrading -->
                                        <StackPanel Visibility="{Binding IsTrainingUpgrading, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <EventTrigger RoutedEvent="Loaded">
                                                                    <BeginStoryboard>
                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="UPGRADE IN PROGRESS" Foreground="#F59E0B" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TrainingCompletionText}" Foreground="#8888AA" FontSize="13" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- If Not Upgrading -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTrainingUpgrading}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                                                    <TextBlock Text="Upgrade Cost: " Foreground="#8888AA" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding TrainingUpgradeCostText}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <Button Content="Upgrade Facility" Command="{Binding UpgradeTrainingFacilityCommand}"
                                                        IsEnabled="{Binding CanUpgradeTraining}"
                                                        Background="#E94560" Foreground="White" FontWeight="Bold"
                                                        FontSize="14" Padding="25,12" Cursor="Hand" BorderThickness="0" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FF5E7E"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="#2D3748"/>
                                                                    <Setter Property="Foreground" Value="#555577"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Helper message for disabled buttons -->
                                                <TextBlock Foreground="#666688" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanUpgradeTraining}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="Only one upgrade can run at a time. Requires sufficient club balance."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 2: Youth Academy -->
                        <Border Grid.Column="2" Background="#16213E" CornerRadius="20" Padding="30">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" Opacity="0.1" ShadowDepth="5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Image Grid.Row="0" Source="/Assets/icons/youth_academy.png" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,15" RenderOptions.BitmapScalingMode="HighQuality"/>

                                <TextBlock Grid.Row="1" Text="YOUTH ACADEMY" FontSize="18" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                <Border Grid.Row="2" Background="{Binding YouthFacilityColour}" CornerRadius="8" Padding="12,6" HorizontalAlignment="Center" Margin="0,0,0,15">
                                    <TextBlock Text="{Binding YouthFacilityLabel}" Foreground="White" FontSize="14" FontWeight="ExtraBold"/>
                                </Border>

                                <TextBlock Grid.Row="3" Text="{Binding YouthFacilityDescription}" Foreground="#8888AA" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Height="65" Margin="0,0,0,15"/>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=0}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=1}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=2}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=3}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=4}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=5}"/>
                                    <Ellipse Width="12" Height="12" Margin="5,0" Fill="{Binding YouthFacilityColour}" Opacity="{Binding YouthFacilityLevel, Converter={StaticResource LevelToOpacityConverter}, ConverterParameter=6}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Visibility="{Binding IsPlayerTeam, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Separator Background="#1A264F" Height="1" Margin="0,0,0,25"/>

                                <Grid>
                                    <!-- Max Level -->
                                    <StackPanel Visibility="{Binding YouthFacilityLevel, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=6}" HorizontalAlignment="Center">
                                        <TextBlock Text="MAXIMUM LEVEL REACHED" Foreground="#84CC16" FontSize="16" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10"/>
                                    </StackPanel>

                                    <!-- Under max level -->
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding YouthFacilityLevel}" Value="6">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!-- If Upgrading -->
                                        <StackPanel Visibility="{Binding IsYouthUpgrading, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <EventTrigger RoutedEvent="Loaded">
                                                                    <BeginStoryboard>
                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="UPGRADE IN PROGRESS" Foreground="#F59E0B" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding YouthCompletionText}" Foreground="#8888AA" FontSize="13" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- If Not Upgrading -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsYouthUpgrading}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                                                    <TextBlock Text="Upgrade Cost: " Foreground="#8888AA" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding YouthUpgradeCostText}" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <Button Content="Upgrade Academy" Command="{Binding UpgradeYouthFacilityCommand}"
                                                        IsEnabled="{Binding CanUpgradeYouth}"
                                                        Background="#E94560" Foreground="White" FontWeight="Bold"
                                                        FontSize="14" Padding="25,12" Cursor="Hand" BorderThickness="0" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FF5E7E"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="#2D3748"/>
                                                                    <Setter Property="Foreground" Value="#555577"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Helper message for disabled buttons -->
                                                <TextBlock Foreground="#666688" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanUpgradeYouth}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="Only one upgrade can run at a time. Requires sufficient club balance."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- SQUAD TAB -->
            <TabItem Header="SQUAD" Style="{StaticResource TabHeaderStyle}">
                <views:TeamRosterView DataContext="{Binding SquadVM}" Margin="0,-30,0,0"/>
            </TabItem>

            <!-- HISTORY TAB -->
            <TabItem Header="HISTORY" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="HONOURS" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560" Margin="4,0,0,20"/>
                        
                        <ItemsControl ItemsSource="{Binding Trophies}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="240" Background="#16213E" CornerRadius="20" Padding="20" Margin="0,0,20,20">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Image Source="{Binding ImagePath}" Width="100" Height="100" Margin="0,0,0,15" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Black" HorizontalAlignment="Center"/>
                                            <Border Background="#1A2238" CornerRadius="10" Padding="12,4" Margin="0,10,0,0" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="WON" Foreground="#666688" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#E94560" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" TIMES" Foreground="#666688" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="No major trophies won yet." Foreground="#444466" FontStyle="Italic" FontSize="16" HorizontalAlignment="Center" Margin="0,50,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Trophies.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
