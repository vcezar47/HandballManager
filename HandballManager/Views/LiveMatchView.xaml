<UserControl x:Class="HandballManager.Views.LiveMatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HandballManager.ViewModels"
             xmlns:conv="clr-namespace:HandballManager.Converters"
             Background="#101827">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TeamLogoPathConverter x:Key="LogoConverter"/>
        
        <Style x:Key="SpeedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PlayerCardTemplate">
            <Button Command="{Binding DataContext.OpenSubstitutionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                    Background="#1F2937" BorderThickness="0" Margin="4,0" Cursor="Hand" Width="105">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Position}" Foreground="#38BDF8" FontWeight="Black" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,2"/>
                                <TextBlock Text="{Binding LiveRating, StringFormat='{}★ {0:F1}'}" 
                                           Foreground="{Binding LiveRating, Converter={StaticResource RatingToColor}}" 
                                           FontWeight="Black" FontSize="11" HorizontalAlignment="Center"/>
                                <Grid Margin="0,6,0,0">
                                    <Border Background="#111827" Height="4" CornerRadius="2"/>
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding EnergyPercent}" Height="4" BorderThickness="0" Background="Transparent" Foreground="#10B981"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#374151"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
        
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar" Cursor="Arrow" HorizontalAlignment="Right" Maximum="{TemplateBinding ScrollableHeight}" Minimum="0" Orientation="Vertical" Visibility="{TemplateBinding VerticalScrollBarVisibility}" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Width="6">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                                <Track.Thumb>
                                                    <Thumb x:Name="Thumb" Background="#374151" Style="{x:Null}">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="Auto"/> <!-- Possession Bar -->
            <RowDefinition Height="*"/>    <!-- Main Body -->
            <RowDefinition Height="Auto"/> <!-- Bottom Cards -->
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#111827" Padding="20" BorderBrush="#1F2937" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="⏸" Command="{Binding TogglePauseCommand}" Style="{StaticResource SpeedButtonStyle}" FontSize="16"/>
                    <Button Content="1x" Command="{Binding SetSpeedCommand}" CommandParameter="1" Style="{StaticResource SpeedButtonStyle}"/>
                    <Button Content="4x" Command="{Binding SetSpeedCommand}" CommandParameter="4" Style="{StaticResource SpeedButtonStyle}"/>
                    <Button Content="16x" Command="{Binding SetSpeedCommand}" CommandParameter="16" Style="{StaticResource SpeedButtonStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="{Binding HomeTeamLogo, Converter={StaticResource LogoConverter}}" Width="32" Height="32" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding HomeTeamName}" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Border Background="#030712" CornerRadius="8" Padding="25,12">
                        <StackPanel>
                            <TextBlock Text="{Binding MatchPhaseLabel}" Foreground="#F59E0B" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding MatchClock}" Foreground="#9CA3AF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Foreground="#EF4444" FontSize="32" FontWeight="Black" HorizontalAlignment="Center">
                                <Run Text="{Binding HomeScore}"/>
                                <Run Text=" : " Foreground="White"/>
                                <Run Text="{Binding AwayScore}"/>
                            </TextBlock>
                            <!-- Shootout score -->
                            <TextBlock Foreground="#FBBF24" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"
                                       Visibility="{Binding IsShootoutActive, Converter={StaticResource BoolToVis}}">
                                <Run Text="("/>
                                <Run Text="{Binding HomeShootoutScore, FallbackValue=0}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding AwayShootoutScore, FallbackValue=0}"/>
                                <Run Text=" pens)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding AwayTeamName}" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,12,0"/>
                    <Image Source="{Binding AwayTeamLogo, Converter={StaticResource LogoConverter}}" Width="32" Height="32" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding SkipToResultCommand}" Background="#374151" Foreground="White" Width="140" Height="40" Margin="0,0,12,0" Cursor="Hand" Visibility="{Binding IsMatchOver, Converter={StaticResource InverseBool}, ConverterParameter='Inverse'}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <TextBlock Text="SKIP TO RESULT" FontWeight="Black" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1F2937"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding CallTimeoutCommand}" Background="#F59E0B" Foreground="#111827" BorderThickness="0" Width="140" Height="40" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="TIME-OUT " FontWeight="Black" FontSize="11"/>
                                        <TextBlock Text="{Binding TimeoutsRemaining, StringFormat='({0}/3)'}" FontWeight="Black" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D97706"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Possession Indicator -->
        <Border Grid.Row="1" Background="#1F2937" Height="50">
            <Grid Margin="40,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="4" VerticalAlignment="Center" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#374151"/><Style.Triggers><DataTrigger Binding="{Binding HomeHasPossession}" Value="True"><Setter Property="Background" Value="#38BDF8"/></DataTrigger></Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="PHASE: " Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPhase}" Foreground="White" FontSize="13" FontWeight="Black" VerticalAlignment="Center">
                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><DataTrigger Binding="{Binding CurrentPhase}" Value="Finishing"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="2" Height="4" VerticalAlignment="Center" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#374151"/><Style.Triggers><DataTrigger Binding="{Binding HomeHasPossession}" Value="False"><Setter Property="Background" Value="#EF4444"/></DataTrigger></Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="2" Margin="30">
            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>

            <!-- Opponent Column (Scrollable) -->
            <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="15" BorderBrush="#1F2937" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="OPPONENT" Foreground="#9CA3AF" FontWeight="Bold" FontSize="11" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding OpponentStartingCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1F2937" CornerRadius="6" Padding="10" Margin="0,0,8,8">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Position}" Foreground="#9CA3AF" FontWeight="Bold" FontSize="9"/>
                                                <TextBlock Text="{Binding LiveRating, StringFormat='{}{0:F1} ★'}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="11" Margin="0,3" TextTrimming="CharacterEllipsis"/>
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding EnergyPercent}" Height="3" BorderThickness="0" Foreground="#EF4444" Background="#111827"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Central Timeline -->
            <Border Grid.Column="1" Background="#030712" CornerRadius="15" Margin="25,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="MATCH TIMELINE" Foreground="#38BDF8" FontWeight="Black" FontSize="12" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding EventFeed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="20,15" CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#111827"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EventType}" Value="Goal"><Setter Property="Background" Value="#064E3B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="Save"><Setter Property="Background" Value="#1E3A8A"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="Miss"><Setter Property="Background" Value="#450A0A"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Foreground="#38BDF8" FontWeight="Black" FontSize="14" VerticalAlignment="Center">
                                                <Run Text="{Binding Minute}"/><Run Text="'"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="White" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Match Stats Dashboard -->
            <Border Grid.Column="2" Background="#111827" CornerRadius="12" Padding="20" BorderBrush="#1F2937" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MATCH DASHBOARD" Foreground="#9CA3AF" FontWeight="Bold" FontSize="11" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <TextBlock Text="VENUE" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VenueName}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,2,0,15" TextWrapping="Wrap"/>
                    <Border Height="1" Background="#1F2937" Margin="0,5,0,15"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="HOME" Foreground="#38BDF8" FontSize="9" FontWeight="Black" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="AWAY" Foreground="#EF4444" FontSize="9" FontWeight="Black" HorizontalAlignment="Right"/>
                        
                        <!-- Possession -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10">
                            <TextBlock Style="{StaticResource StatLabelStyle}" Text="POSSESSION"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource StatValueStyle}" Text="{Binding HomePossessionPercent, StringFormat='{}{0:F0}%'}" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Column="1" Style="{StaticResource StatValueStyle}" Text="{Binding AwayPossessionPercent, StringFormat='{}{0:F0}%'}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Total Shots -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10">
                            <TextBlock Style="{StaticResource StatLabelStyle}" Text="TOTAL SHOTS"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource StatValueStyle}" Text="{Binding HomeShots}" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Column="1" Style="{StaticResource StatValueStyle}" Text="{Binding AwayShots}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Shots on Target -->
                        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,10">
                            <TextBlock Style="{StaticResource StatLabelStyle}" Text="SHOTS ON TARGET"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource StatValueStyle}" Text="{Binding HomeShotsOnTarget}" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Column="1" Style="{StaticResource StatValueStyle}" Text="{Binding AwayShotsOnTarget}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Efficiency -->
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="0,10">
                            <TextBlock Style="{StaticResource StatLabelStyle}" Text="EFFICIENCY"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource StatValueStyle}" Text="{Binding HomeEfficiencyText}" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Column="1" Style="{StaticResource StatValueStyle}" Text="{Binding AwayEfficiencyText}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom Cards -->
        <Border Grid.Row="3" Background="#111827" Padding="25" BorderBrush="#1F2937" BorderThickness="0,1,0,0">
            <ItemsControl ItemsSource="{Binding UserStartingCards}" ItemTemplate="{StaticResource PlayerCardTemplate}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>

        <!-- Overlays -->
        <Grid Grid.RowSpan="4" Background="#E0000000" Visibility="{Binding IsSubstitutionPanelOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#111827" CornerRadius="15" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Width="450" BorderBrush="#1F2937" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="TACTICAL SUBSTITUTION" Foreground="#EF4444" FontSize="18" FontWeight="Black" Margin="0,0,0,25"/>
                    <TextBlock Text="{Binding PlayerBeingSubstituted.Name, StringFormat='{}Retiring: {0}'}" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding PlayerBeingSubstituted.Position}" Foreground="#38BDF8" FontSize="12" FontWeight="Black" Margin="0,0,0,25"/>
                    <ScrollViewer MaxHeight="350" Margin="0,0,0,30">
                        <ItemsControl ItemsSource="{Binding AvailableSubstitutes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ConfirmSubstituteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#1F2937" BorderThickness="0" Margin="0,0,0,10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="15">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Position}" Foreground="#38BDF8" FontWeight="Black"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding NaturalFitness}" Foreground="#9CA3AF" FontSize="10" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MatchEnergy, StringFormat='{}{0:F0}%'}" Foreground="#10B981" FontSize="10" FontWeight="Black" HorizontalAlignment="Right"/>
                                                            <Border Height="3" Background="#111827" CornerRadius="1.5" Margin="0,2,0,0">
                                                                <ProgressBar Value="{Binding MatchEnergy}" Minimum="0" Maximum="100" Height="3" BorderThickness="0" Background="Transparent" Foreground="#10B981"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#374151"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Content="CANCEL" Command="{Binding CloseSubstitutionCommand}" Background="#374151" Foreground="White" FontWeight="Bold" Padding="0,15" BorderThickness="0">
                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="4" Background="#F0000000" Visibility="{Binding IsHalfTime, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="HALF TIME" Foreground="White" FontSize="64" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Image Source="{Binding HomeTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Foreground="#EF4444" FontSize="48" FontWeight="Black" VerticalAlignment="Center">
                        <Run Text="{Binding HomeScore}"/><Run Text=" - " Foreground="White"/><Run Text="{Binding AwayScore}"/>
                    </TextBlock>
                    <Image Source="{Binding AwayTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="20,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>
                <Button Content="START SECOND HALF" Command="{Binding StartSecondHalfCommand}" Background="#10B981" Foreground="White" FontSize="18" FontWeight="Black" Padding="40,20" BorderThickness="0">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </Grid>
        <!-- Extra Time Half Time -->
        <Grid Grid.RowSpan="4" Background="#F0000000" Visibility="{Binding IsExtraTimeHalfTime, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="EXTRA TIME BREAK" Foreground="White" FontSize="56" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Image Source="{Binding HomeTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Foreground="#EF4444" FontSize="48" FontWeight="Black" VerticalAlignment="Center">
                        <Run Text="{Binding HomeScore}"/><Run Text=" - " Foreground="White"/><Run Text="{Binding AwayScore}"/>
                    </TextBlock>
                    <Image Source="{Binding AwayTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="20,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>
                <Button Content="START ET SECOND HALF" Command="{Binding StartExtraTimeSecondHalfCommand}" Background="#10B981" Foreground="White" FontSize="18" FontWeight="Black" Padding="40,20" BorderThickness="0">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Timeout Overlay -->
        <Grid Grid.RowSpan="4" Background="#D0000000" Visibility="{Binding IsTimeoutActive, Converter={StaticResource BoolToVis}}">
            <Border Background="#111827" CornerRadius="15" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" BorderBrush="#F59E0B" BorderThickness="3">
                <StackPanel>
                    <TextBlock Text="TIME-OUT CALLED" Foreground="#F59E0B" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Image Source="{Binding TimeoutCallerLogo, Converter={StaticResource LogoConverter}}" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding TimeoutCallerName, StringFormat='{}by {0}'}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    
                    <Button Content="RESUME MATCH" Command="{Binding DismissTimeoutCommand}" Background="#F59E0B" Foreground="#111827" FontSize="16" FontWeight="Black" Padding="0,15" BorderThickness="0">
                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.RowSpan="4" Background="#F0000000" Visibility="{Binding IsMatchOver, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="FULL TIME" Foreground="White" FontSize="64" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Image Source="{Binding HomeTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Foreground="#EF4444" FontSize="48" FontWeight="Black" HorizontalAlignment="Center">
                            <Run Text="{Binding HomeScore}"/><Run Text=" - " Foreground="White"/><Run Text="{Binding AwayScore}"/>
                        </TextBlock>
                        <TextBlock Foreground="#FBBF24" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"
                                   Visibility="{Binding IsShootoutActive, Converter={StaticResource BoolToVis}}">
                            <Run Text="("/>
                            <Run Text="{Binding HomeShootoutScore, FallbackValue=0}"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding AwayShootoutScore, FallbackValue=0}"/>
                            <Run Text=" pens)"/>
                        </TextBlock>
                    </StackPanel>
                    <Image Source="{Binding AwayTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" VerticalAlignment="Center" Margin="20,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>
                <Button Content="PROCEED TO SUMMARY" Command="{Binding ViewMatchSummaryCommand}" Background="#EF4444" Foreground="White" FontSize="18" FontWeight="Black" Padding="40,20" BorderThickness="0">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
