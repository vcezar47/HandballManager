<UserControl x:Class="HandballManager.Views.ScoutingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HandballManager.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ScoutingViewModel}">

    <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="SCOUTING" FontSize="11" FontWeight="ExtraBold"
                       Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
            <TextBlock Text="Assignments &amp; Shortlist" FontSize="36" FontWeight="Black"
                       Foreground="White" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Active scouting -->
        <Border Grid.Row="1" CornerRadius="20" Background="#16213E" Padding="24" Margin="0,0,0,24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.18" ShadowDepth="6"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ACTIVE ASSIGNMENTS" Foreground="#A0A8C0" FontWeight="ExtraBold" FontSize="11" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActiveScoutingTitle}" Foreground="White" FontWeight="Black" FontSize="22"/>
                    <TextBlock Text="{Binding ActiveScoutingSubtitle}" Foreground="#A0A8C0" FontSize="13" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A2238" CornerRadius="14" Padding="12,6" Margin="0,0,14,0" BorderBrush="#2A2A4A" BorderThickness="1">
                        <TextBlock Text="{Binding DaysRemaining, StringFormat={} {0}d}" Foreground="#38BDF8" FontWeight="Black" FontSize="14"/>
                    </Border>
                    <Button Content="CANCEL"
                            Command="{Binding CancelScoutingCommand}"
                            Background="#334155" Foreground="White" FontWeight="Black"
                            Padding="18,10" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Shortlist -->
        <Border Grid.Row="2" CornerRadius="20" Background="#16213E" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.2" ShadowDepth="10"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding Shortlist}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      RowBackground="Transparent"
                      BorderThickness="0"
                      FontFamily="Segoe UI"
                      FontSize="14"
                      Foreground="White"
                      ColumnHeaderHeight="45"
                      RowHeight="48"
                      HeadersVisibility="Column"
                      SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Foreground"      Value="#A0A8C0"/>
                        <Setter Property="FontWeight"      Value="ExtraBold"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="Padding"         Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush"     Value="#2A2A4A"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="PLAYER" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ViewPlayerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="👤" Foreground="#666688" Margin="0,0,10,0" FontSize="16" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                <TextBlock Text="  •  " Foreground="#444466" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TeamName}" Foreground="#A0A8C0" FontWeight="SemiBold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="POS" Binding="{Binding Position}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="FontWeight"          Value="Bold"/>
                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground"          Value="#666688"/>
                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="OVR" Binding="{Binding OverallDisplay}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="FontWeight"          Value="Black"/>
                                <Setter Property="Foreground"          Value="#E94560"/>
                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.RemoveFromShortlistCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#334155" CornerRadius="8" Padding="10,5">
                                                <TextBlock Text="REMOVE" Foreground="White" FontWeight="Bold"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

