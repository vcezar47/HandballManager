<UserControl x:Class="HandballManager.Views.MatchDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:HandballManager.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#0F172A">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
    </UserControl.Resources>
    <Grid Margin="20" MaxWidth="1000">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Score & Teams -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0" Content="← BACK" 
                        Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#334155" Foreground="White" FontWeight="Bold" Padding="12,6" 
                        Margin="0,0,20,0" VerticalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Home Logo Placeholder -->
                <Border Grid.Column="1" Width="80" Height="80" Background="#1A2238" CornerRadius="40" BorderBrush="#38BDF8" BorderThickness="3" VerticalAlignment="Center">
                    <Image Source="{Binding Match.HomeTeamLogo, Converter={StaticResource TeamLogoPathConverter}}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Center: Scores & Team Names -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Match.HomeGoals}" FontSize="54" FontWeight="Black" Foreground="#38BDF8"/>
                        <TextBlock Text=" – " FontSize="54" FontWeight="Black" Foreground="#38BDF8"/>
                        <TextBlock Text="{Binding Match.AwayGoals}" FontSize="54" FontWeight="Black" Foreground="#38BDF8"/>
                        <StackPanel.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.6" Color="#38BDF8"/>
                        </StackPanel.Effect>
                    </StackPanel>

                    <!-- Penalty Score Display -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,-10,0,5" Visibility="{Binding Match.WasDecidedByShootout, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="PENALTIES: " FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Match.HomePenaltyGoals}" FontSize="18" FontWeight="Black" Foreground="#E94560"/>
                        <TextBlock Text=" – " FontSize="18" FontWeight="Black" Foreground="#94A3B8"/>
                        <TextBlock Text="{Binding Match.AwayPenaltyGoals}" FontSize="18" FontWeight="Black" Foreground="#E94560"/>
                    </StackPanel>

                    <!-- AET Status -->
                    <Border Background="#1E293B" HorizontalAlignment="Center" Padding="8,2" CornerRadius="4" Margin="0,0,0,10"
                            Visibility="{Binding Match.WasDecidedByOvertime, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="AFTER EXTRA TIME" Foreground="#64748B" FontSize="10" FontWeight="Black"/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,-5,0,0">
                        <Button Content="{Binding Match.HomeTeamName}" 
                                Click="HomeTeam_Click"
                                Foreground="White" FontSize="18" FontWeight="Black" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <TextBlock Text=" vs " Foreground="#94A3B8" FontSize="18" FontWeight="Normal" VerticalAlignment="Center" Margin="10,0"/>
                        <Button Content="{Binding Match.AwayTeamName}" 
                                Click="AwayTeam_Click"
                                Foreground="White" FontSize="18" FontWeight="Black" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Match.PlayedOn, StringFormat='{}{0:dd MMMM yyyy}'}" Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <TextBlock Text="VENUE: " Foreground="#64748B" FontSize="11" FontWeight="ExtraBold"/>
                        <TextBlock Text="{Binding Match.VenueName}" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="ATTENDANCE: " Foreground="#64748B" FontSize="11" FontWeight="ExtraBold"/>
                        <TextBlock Text="{Binding Match.Attendance, StringFormat={}{0:N0}}" Foreground="#38BDF8" FontSize="11" FontWeight="Black"/>
                    </StackPanel>
                </StackPanel>

                <!-- Away Logo Placeholder -->
                <Border Grid.Column="3" Width="80" Height="80" Background="#1A2238" CornerRadius="40" BorderBrush="#E94560" BorderThickness="3" VerticalAlignment="Center">
                    <Image Source="{Binding Match.AwayTeamLogo, Converter={StaticResource TeamLogoPathConverter}}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Score History Section -->
                <Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,25" MaxHeight="400">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SCORE HISTORY" Foreground="#A0A8C0" FontWeight="ExtraBold" FontSize="11" Margin="5,0,0,15"/>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ScoreHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Home Scorer -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding IsHomeGoal, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Run Text="{Binding PlayerName}" FontWeight="SemiBold"/>
                                                    <Run Text=" (" Foreground="#38BDF8"/><Run Text="{Binding Minute}" Foreground="#38BDF8"/><Run Text="')" Foreground="#38BDF8"/>
                                                </TextBlock>
                                                <Border Width="8" Height="8" CornerRadius="4" Background="#38BDF8" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                            </StackPanel>

                                            <!-- Score Middle -->
                                            <Border Grid.Column="1" Background="#1A2238" CornerRadius="12" Padding="15,6" BorderBrush="#2A3248" BorderThickness="1" MinWidth="110">
                                                <TextBlock Text="{Binding ScoreText}" Foreground="White" FontSize="16" FontWeight="Black" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                            </Border>

                                            <!-- Away Scorer -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="{Binding IsHomeGoal, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                <Border Width="8" Height="8" CornerRadius="4" Background="#E94560" VerticalAlignment="Center" Margin="15,0,8,0"/>
                                                <TextBlock Foreground="White" FontSize="13" VerticalAlignment="Center">
                                                    <Run Text="{Binding PlayerName}" FontWeight="SemiBold"/>
                                                    <Run Text=" (" Foreground="#E94560"/><Run Text="{Binding Minute}" Foreground="#E94560"/><Run Text="')" Foreground="#E94560"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Player Stats Section -->
                <Border Background="#1E293B" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="PLAYER PERFORMANCE" Foreground="#A0A8C0" FontWeight="ExtraBold" FontSize="11" Margin="5,0,0,20"/>
                        
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="Border" Background="#253248" CornerRadius="8,8,0,0" Padding="25,12" Margin="0,0,5,0">
                                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <ContentPresenter.Resources>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="FontSize" Value="13"/>
                                                            </Style>
                                                        </ContentPresenter.Resources>
                                                    </ContentPresenter>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#38BDF8"/>
                                                        <Setter Property="Foreground" Value="#0F172A"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background" Value="#2D3B55"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="RowBackground" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="GridLinesVisibility" Value="None"/>
                                    <Setter Property="IsReadOnly" Value="True"/>
                                    <Setter Property="CanUserAddRows" Value="False"/>
                                    <Setter Property="SelectionMode" Value="Single"/>
                                    <Setter Property="HeadersVisibility" Value="Column"/>
                                    <Setter Property="RowHeight" Value="45"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#A0A8C0"/>
                                    <Setter Property="Padding" Value="15,10"/>
                                    <Setter Property="FontWeight" Value="ExtraBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#2A3248"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#252F45"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#253248"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="15,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Resources>

                            <!-- Home Team Tab -->
                            <TabItem Header="{Binding Match.HomeTeamName}">
                                <Border Background="#16213E" CornerRadius="0,12,12,12" Padding="5">
                                    <DataGrid ItemsSource="{Binding HomePlayerStats}" AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="PLAYER" Width="*">
                                                <DataGridTemplateColumn.HeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                    </Style>
                                                </DataGridTemplateColumn.HeaderStyle>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding PlayerName}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            
                                            <DataGridTextColumn Header="GOALS" Binding="{Binding Goals}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTextColumn Header="ASSISTS" Binding="{Binding Assists}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTextColumn Header="SAVES" Binding="{Binding Saves}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTemplateColumn Header="RATING" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#38BDF8" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,4">
                                                            <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}" Foreground="#0F172A" FontWeight="Black" FontSize="13"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </TabItem>

                            <!-- Away Team Tab -->
                            <TabItem Header="{Binding Match.AwayTeamName}">
                                <Border Background="#16213E" CornerRadius="0,12,12,12" Padding="5">
                                    <DataGrid ItemsSource="{Binding AwayPlayerStats}" AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="PLAYER" Width="*">
                                                <DataGridTemplateColumn.HeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                    </Style>
                                                </DataGridTemplateColumn.HeaderStyle>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding PlayerName}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            
                                            <DataGridTextColumn Header="GOALS" Binding="{Binding Goals}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTextColumn Header="ASSISTS" Binding="{Binding Assists}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTextColumn Header="SAVES" Binding="{Binding Saves}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            
                                            <DataGridTemplateColumn Header="RATING" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#E94560" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,4">
                                                            <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}" Foreground="White" FontWeight="Black" FontSize="13"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
