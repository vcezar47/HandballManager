<UserControl x:Class="HandballManager.Views.LeagueTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="LeagueDgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A8C0"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LeagueDgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1E1E3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2238"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LeagueDgCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="KvMiniClubColumnCell">
            <Button Command="{Binding DataContext.ViewTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                            <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <TextBlock Text="STANDINGS" FontSize="11" FontWeight="ExtraBold"
                           Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
                <Button Command="{Binding ViewLeagueHistoryCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Padding="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{Binding CompetitionName, StringFormat='{}{0} Table'}" FontSize="36" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI" x:Name="TitleText"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TitleText" Property="Foreground" Value="#E94560"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Table Container -->
            <Border Grid.Row="1" CornerRadius="20" Background="#16213E" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.2" ShadowDepth="10"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Kvindeligaen tab strip (CupDetailView style) -->
                    <Border CornerRadius="20,20,0,0" Background="#0F172A" Padding="8,8,8,0"
                            Visibility="{Binding IsKvindeligaen, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <!-- Regular season tab -->
                            <Button Command="{Binding SelectKvindeligaenTabCommand}" CommandParameter="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="20,10" Margin="0,0,4,0">
                                            <TextBlock x:Name="TabText" Text="REGULAR SEASON" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding SelectedKvTabName}" Value="Regular">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                                <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Group stage tab -->
                            <Button Command="{Binding SelectKvindeligaenTabCommand}" CommandParameter="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="20,10" Margin="0,0,4,0">
                                            <TextBlock x:Name="TabText" Text="GROUP STAGE" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding SelectedKvTabName}" Value="GroupStage">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                                <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Knockout tab -->
                            <Button Command="{Binding SelectKvindeligaenTabCommand}" CommandParameter="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10,10,0,0" Padding="20,10" Margin="0,0,4,0">
                                            <TextBlock x:Name="TabText" Text="KNOCKOUT" FontFamily="Segoe UI" FontSize="13" FontWeight="ExtraBold" Foreground="#8888AA"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding SelectedKvTabName}" Value="Knockout">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                                <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding KvindeligaenTableSectionTitle}" FontFamily="Segoe UI" FontWeight="SemiBold"
                               Foreground="#A0A8C0" FontSize="12" Margin="20,14,20,14" TextWrapping="Wrap"
                               Visibility="{Binding IsKvindeligaen, Converter={StaticResource BoolToVis}}"/>

                    <!-- Standard full league grid -->
                    <DataGrid Visibility="{Binding ShowStandardStandingsGrid, Converter={StaticResource BoolToVis}}"
                              ItemsSource="{Binding Standings}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserReorderColumns="False"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              RowBackground="Transparent"
                              BorderThickness="0"
                              FontFamily="Segoe UI"
                              FontSize="14"
                              Foreground="White"
                              ColumnHeaderHeight="40"
                              RowHeight="40"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Margin="15,0"
                              ColumnHeaderStyle="{StaticResource LeagueDgHeaderStyle}"
                              RowStyle="{StaticResource LeagueDgRowStyle}"
                              CellStyle="{StaticResource LeagueDgCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="POS" Binding="{Binding Rank}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#666688"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Qualification cue (Green bar for top 8 in Kv regular) -->
                            <DataGridTemplateColumn Width="12">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="3" Height="22" CornerRadius="1.5" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="1"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="2"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="3"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="4"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="5"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="6"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="7"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding DataContext.IsKvindeligaen, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                                                                <Condition Binding="{Binding Rank}" Value="8"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#4ADE80"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="CLUB" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ViewTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                                        <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#A0A8C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="W" Binding="{Binding Won}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#4ADE80"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="D" Binding="{Binding Drawn}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="L" Binding="{Binding Lost}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="GF" Binding="{Binding GoalsFor}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="GA" Binding="{Binding GoalsAgainst}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Black"/>
                                        <Setter Property="Foreground" Value="#E94560"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Mini league grids (Kv group stage) -->
                    <StackPanel Visibility="{Binding KvShowGroupTables, Converter={StaticResource BoolToVis}}"
                                Margin="15,0">
                        <TextBlock Text="Championship group A" Margin="8,12,8,10" FontWeight="Black" FontSize="13" Foreground="#E94560" FontFamily="Segoe UI"/>
                        <DataGrid ItemsSource="{Binding ChampGroupAStandings}" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  IsReadOnly="True" GridLinesVisibility="None" Background="Transparent" RowBackground="Transparent"
                                  BorderThickness="0" Margin="0,0,0,24" ColumnHeaderHeight="36" RowHeight="38"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderStyle="{StaticResource LeagueDgHeaderStyle}"
                                  RowStyle="{StaticResource LeagueDgRowStyle}"
                                  CellStyle="{StaticResource LeagueDgCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="POS" Binding="{Binding Rank}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Qualification cue (Green bar for top 2) -->
                                <DataGridTemplateColumn Width="12">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="3" Height="20" CornerRadius="1.5" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Rank}" Value="1">
                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rank}" Value="2">
                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="CLUB" Width="*" CellTemplate="{StaticResource KvMiniClubColumnCell}"/>
                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="W" Binding="{Binding Won}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="D" Binding="{Binding Drawn}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="L" Binding="{Binding Lost}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#F87171"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Championship group B" Margin="8,0,8,10" FontWeight="Black" FontSize="13" Foreground="#E94560" FontFamily="Segoe UI"/>
                        <DataGrid ItemsSource="{Binding ChampGroupBStandings}" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  IsReadOnly="True" GridLinesVisibility="None" Background="Transparent" RowBackground="Transparent"
                                  BorderThickness="0" Margin="0,0,0,24" ColumnHeaderHeight="36" RowHeight="38"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderStyle="{StaticResource LeagueDgHeaderStyle}"
                                  RowStyle="{StaticResource LeagueDgRowStyle}"
                                  CellStyle="{StaticResource LeagueDgCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="POS" Binding="{Binding Rank}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Qualification cue (Green bar for top 2) -->
                                <DataGridTemplateColumn Width="12">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="3" Height="20" CornerRadius="1.5" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Rank}" Value="1">
                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rank}" Value="2">
                                                                <Setter Property="Background" Value="#4ADE80"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="CLUB" Width="*" CellTemplate="{StaticResource KvMiniClubColumnCell}"/>
                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="W" Binding="{Binding Won}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="D" Binding="{Binding Drawn}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="L" Binding="{Binding Lost}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#F87171"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Relegation group" Margin="8,0,8,10" FontWeight="Black" FontSize="13" Foreground="#E94560" FontFamily="Segoe UI"/>
                        <DataGrid ItemsSource="{Binding RelegationGroupStandings}" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  IsReadOnly="True" GridLinesVisibility="None" Background="Transparent" RowBackground="Transparent"
                                  BorderThickness="0" Margin="0,0,0,8" ColumnHeaderHeight="36" RowHeight="38"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderStyle="{StaticResource LeagueDgHeaderStyle}"
                                  RowStyle="{StaticResource LeagueDgRowStyle}"
                                  CellStyle="{StaticResource LeagueDgCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="POS" Binding="{Binding Rank}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="CLUB" Width="*" CellTemplate="{StaticResource KvMiniClubColumnCell}"/>
                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="W" Binding="{Binding Won}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="D" Binding="{Binding Drawn}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="L" Binding="{Binding Lost}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#F87171"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Knockout fixtures -->
                    <ItemsControl Margin="15,16,15,16" Visibility="{Binding KvShowKnockoutList, Converter={StaticResource BoolToVis}}"
                                  ItemsSource="{Binding KvindeligaenKnockoutRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="20,14" Margin="0,0,0,10" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A2238"/>
                                            <Setter Property="BorderBrush" Value="#2A3448"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFinal}" Value="True">
                                                    <Setter Property="Background" Value="#2A1B38"/>
                                                    <Setter Property="BorderBrush" Value="#E94560"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Caption}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A0A8C0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFinal}" Value="True">
                                                            <Setter Property="Foreground" Value="#E94560"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding HomeName}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Right" Margin="0,0,12,0"/>
                                            <Image Grid.Column="1" Source="{Binding HomeLogo, Converter={StaticResource TeamLogoPathConverter}}" Width="30" Height="30" VerticalAlignment="Center"/>
                                            
                                            <Border Grid.Column="2" Background="#16213E" CornerRadius="8" Padding="14,8" Margin="16,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ScoreText}" Foreground="#E94560" FontWeight="Black" FontSize="17"/>
                                            </Border>
                                            
                                            <Image Grid.Column="3" Source="{Binding AwayLogo, Converter={StaticResource TeamLogoPathConverter}}" Width="30" Height="30" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding AwayName}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Left" Margin="12,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
