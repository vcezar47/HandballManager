<UserControl x:Class="HandballManager.Views.WorldLeaguesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CompactHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#A0A8C0"/>
            <Setter Property="FontWeight"      Value="ExtraBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="#2A2A4A"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1E1E3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2238"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Clickable title button style -->
        <ControlTemplate x:Key="TitleButtonTemplate" TargetType="Button">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{Binding DataContext.LeagueLogoPath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Width="28" Height="28" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"
                       x:Name="TitleImg"/>
                <TextBlock Text="{Binding DataContext.LeagueDisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="20" FontWeight="Black" Foreground="White"
                           VerticalAlignment="Center" x:Name="TitleText"/>
                <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TitleText" Property="Foreground" Value="#E94560"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="WORLD LEAGUES" FontSize="11" FontWeight="ExtraBold"
                           Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
                <TextBlock Text="International Standings" FontSize="36" FontWeight="Black"
                           Foreground="White" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Nation Selector -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding AvailableCompetitions}" Margin="0,0,0,30">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectCompetitionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding Name}"
                                Background="Transparent" BorderThickness="0" Margin="0,0,20,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="NationBorder" Background="#1A1A2E" CornerRadius="12"
                                            Padding="15,10" BorderThickness="1" BorderBrush="#2A2A4A">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Flag}" Width="24" Height="16" Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding Country}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource EqualityToBool}">
                                                    <Binding Path="Name"/>
                                                    <Binding Path="DataContext.SelectedCompetition" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="NationBorder" Property="Background" Value="#2A2A4A"/>
                                            <Setter TargetName="NationBorder" Property="BorderBrush" Value="#E94560"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="NationBorder" Property="BorderBrush" Value="#E94560"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Content: left always visible; right panel hidden for Hungary -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: League table -->
                <Border Grid.Column="0" CornerRadius="20" Background="#16213E" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- League title — click → league table detail, right-click handled via second button below -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- League name → league detail view -->
                            <Button Grid.Column="0" Command="{Binding ViewLeagueDetailCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0"
                                    HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding LeagueLogoPath}" Width="28" Height="28" Margin="0,0,12,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding LeagueDisplayName}" FontSize="20" FontWeight="Black"
                                                       Foreground="White" VerticalAlignment="Center" x:Name="LeagueTitle"/>
                                            <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="LeagueTitle" Property="Foreground" Value="#E94560"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Archive link → league history -->
                            <Button Grid.Column="1" Command="{Binding ViewLeagueHistoryCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0"
                                    HorizontalAlignment="Right">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="ArchiveText" Text="ARCHIVE  ›" FontSize="11" FontWeight="ExtraBold"
                                                   Foreground="#555577" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ArchiveText" Property="Foreground" Value="#E94560"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Compact league standings -->
                        <DataGrid ItemsSource="{Binding Standings}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserReorderColumns="False" GridLinesVisibility="None"
                                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderHeight="36" RowHeight="36"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  ColumnHeaderStyle="{StaticResource CompactHeaderStyle}"
                                  RowStyle="{StaticResource CompactRowStyle}"
                                  CellStyle="{StaticResource CompactCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="CLUB" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ViewTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                            <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                                   Width="18" Height="18" Margin="0,0,8,0"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold"
                                                                       VerticalAlignment="Center" FontSize="12"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="45">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Spacer (only visible for Romania) -->
                <Grid Grid.Column="1" Width="16" Visibility="{Binding IsRomanianLeague, Converter={StaticResource BoolToVis}}"/>

                <!-- RIGHT: Cupa României + Supercupa (ROMANIA) -->
                <Grid Grid.Column="2" Visibility="{Binding IsRomanianLeague, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cupa României -->
                    <Border Grid.Row="0" CornerRadius="20" Background="#16213E" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Cup title → cup detail -->
                            <Button Command="{Binding ViewCupDetailCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" Margin="0,0,0,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding DataContext.CupLogoPath, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="28" Height="28"
                                                   Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding CupGroupTitle}" FontSize="20" FontWeight="Black"
                                                       Foreground="White" VerticalAlignment="Center" x:Name="CupTitle"/>
                                            <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CupTitle" Property="Foreground" Value="#E94560"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Cup group table -->
                            <DataGrid ItemsSource="{Binding PlayerCupGroup.Entries}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserReorderColumns="False" GridLinesVisibility="None"
                                      Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                      FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                      ColumnHeaderHeight="36" RowHeight="36"
                                      HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                      ColumnHeaderStyle="{StaticResource CompactHeaderStyle}"
                                      RowStyle="{StaticResource CompactRowStyle}"
                                      CellStyle="{StaticResource CompactCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="35">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#666688"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="CLUB" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.ViewCupTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                                <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                                       Width="18" Height="18" Margin="0,0,8,0"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold"
                                                                           VerticalAlignment="Center" FontSize="12"/>
                                                            </StackPanel>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="35">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#A0A8C0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="40">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="45">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Black"/>
                                                <Setter Property="Foreground" Value="#E94560"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Empty state -->
                            <TextBlock Text="Cup draw not yet available."
                                       Foreground="#555577" FontFamily="Segoe UI" FontSize="14"
                                       FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PlayerCupGroup}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Supercupa României -->
                    <Border Grid.Row="2" CornerRadius="20" Background="#16213E" Padding="20" Margin="0,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Supercup title → supercup detail -->
                            <Button Command="{Binding ViewSupercupDetailCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" Margin="0,0,0,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="/Assets/leaguelogo/cuparomaniei.png" Width="28" Height="28"
                                                   Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="Supercupa României" FontSize="20" FontWeight="Black"
                                                       Foreground="White" VerticalAlignment="Center" x:Name="SupercupTitle"/>
                                            <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SupercupTitle" Property="Foreground" Value="#E94560"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Supercup fixtures -->
                            <ItemsControl ItemsSource="{Binding SupercupFixtures}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1A2238" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                                BorderBrush="#252D45" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="11"
                                                               FontWeight="Bold" VerticalAlignment="Center"
                                                               TextWrapping="Wrap" MaxWidth="100" TextAlignment="Right"/>
                                                    <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                           Width="16" Height="16" Margin="6,0,0,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding ScoreDisplay}"
                                                           Foreground="#E94560" FontSize="14" FontWeight="Black"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                           Width="16" Height="16" Margin="0,0,6,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="11"
                                                               FontWeight="Bold" VerticalAlignment="Center"
                                                               TextWrapping="Wrap" MaxWidth="100"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <TextBlock Text="Supercup fixtures not available."
                                       Foreground="#555577" FontFamily="Segoe UI" FontSize="14"
                                       FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SupercupFixtures.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RIGHT: Magyar Kupa (HUNGARY) -->
                <Border Grid.Column="2" Visibility="{Binding IsHungarianLeague, Converter={StaticResource BoolToVis}}" CornerRadius="20" Background="#16213E" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Cup title → cup detail -->
                        <Button Command="{Binding ViewCupDetailCommand}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" Margin="0,0,0,16">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="/Assets/leaguelogo/magyarkupa.png" Width="28" Height="28"
                                               Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding CupGroupTitle}" FontSize="20" FontWeight="Black"
                                                   Foreground="White" VerticalAlignment="Center" x:Name="HuCupTitle"/>
                                        <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HuCupTitle" Property="Foreground" Value="#E94560"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Cup group table -->
                        <DataGrid ItemsSource="{Binding PlayerCupGroup.Entries}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserReorderColumns="False" GridLinesVisibility="None"
                                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderHeight="36" RowHeight="36"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  ColumnHeaderStyle="{StaticResource CompactHeaderStyle}"
                                  RowStyle="{StaticResource CompactRowStyle}"
                                  CellStyle="{StaticResource CompactCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="CLUB" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ViewCupTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                            <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                                   Width="18" Height="18" Margin="0,0,8,0"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold"
                                                                       VerticalAlignment="Center" FontSize="12"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="45">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->
                        <TextBlock Text="Cup draw not yet available."
                                   Foreground="#555577" FontFamily="Segoe UI" FontSize="14"
                                   FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerCupGroup}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- RIGHT: Coupe de France (FRANCE) -->
                <Border Grid.Column="2" Visibility="{Binding IsFrenchLeague, Converter={StaticResource BoolToVis}}" CornerRadius="20" Background="#16213E" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Cup title → cup detail -->
                        <Button Command="{Binding ViewCupDetailCommand}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" Margin="0,0,0,16">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="{Binding DataContext.CupLogoPath, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="28" Height="28"
                                               Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding CupGroupTitle}" FontSize="20" FontWeight="Black"
                                                   Foreground="White" VerticalAlignment="Center" x:Name="FrCupTitle"/>
                                        <TextBlock Text="  ›" FontSize="20" FontWeight="Bold" Foreground="#666688" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FrCupTitle" Property="Foreground" Value="#E94560"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Cup group table -->
                        <DataGrid ItemsSource="{Binding PlayerCupGroup.Entries}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserReorderColumns="False" GridLinesVisibility="None"
                                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="White"
                                  ColumnHeaderHeight="36" RowHeight="36"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                  ColumnHeaderStyle="{StaticResource CompactHeaderStyle}"
                                  RowStyle="{StaticResource CompactRowStyle}"
                                  CellStyle="{StaticResource CompactCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#666688"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="CLUB" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ViewCupTeamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                            <Image Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogoPathConverter}}"
                                                                   Width="18" Height="18" Margin="0,0,8,0"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="{Binding Team.Name}" Foreground="White" FontWeight="Bold"
                                                                       VerticalAlignment="Center" FontSize="12"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="P" Binding="{Binding Played}" Width="35">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A8C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PTS" Binding="{Binding Points}" Width="45">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->
                        <TextBlock Text="Cup draw not yet available."
                                   Foreground="#555577" FontFamily="Segoe UI" FontSize="14"
                                   FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerCupGroup}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
