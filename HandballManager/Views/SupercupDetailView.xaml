<UserControl x:Class="HandballManager.Views.SupercupDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <converters:TeamLogoPathConverter x:Key="TeamLogoPathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1200" HorizontalAlignment="Center" Margin="40,30">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="SUPERCUPA ROMÂNIEI" FontSize="11" FontWeight="ExtraBold"
                           Foreground="#E94560" FontFamily="Segoe UI" Margin="4,0,0,10"/>
                <Button Command="{Binding ViewSupercupHistoryCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Assets/leaguelogo/cuparomaniei.png" Width="40" Height="40" Margin="0,0,16,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Supercupa României" FontSize="36" FontWeight="Black"
                                           Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center" x:Name="HeaderText"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="#E94560"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- KNOCKOUT PHASE CONTENT -->
                <StackPanel Margin="0,24,0,0">
                    <Border CornerRadius="20" Background="#16213E" Padding="30" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Semi-Finals -->
                            <TextBlock Text="SEMI-FINALS" FontSize="13" FontWeight="ExtraBold"
                                       Foreground="#E94560" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding SemiFinals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="MatchBorder" Background="#1A2238" CornerRadius="12" Padding="24,16" Margin="0,0,0,8"
                                                BorderBrush="#252D45" BorderThickness="1" HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#252D45"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#E94560"/>
                                                            <Setter Property="Background" Value="#1E293B"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="10,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding ScoreDisplay}" Foreground="#E94560" FontSize="16" FontWeight="Black" TextAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding VenueName}" Foreground="#666688" FontSize="11" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 3rd Place Match -->
                            <TextBlock Text="3RD PLACE MATCH" FontSize="13" FontWeight="ExtraBold"
                                       Foreground="#A0A8C0" FontFamily="Segoe UI" Margin="0,28,0,16"/>
                            <Border Background="#1A2238" CornerRadius="12" Padding="20,12" Margin="0,0,0,8" 
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding ThirdPlaceMatch, Converter={StaticResource NullToVis}}">
                                <Grid DataContext="{Binding ThirdPlaceMatch}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                         <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="10,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                     </StackPanel>
                                     <Border Grid.Column="1" Background="#16213E" CornerRadius="10" Padding="12,4" HorizontalAlignment="Center">
                                         <TextBlock Text="{Binding ScoreDisplay}" Foreground="#A0A8C0" FontSize="16" FontWeight="Black" TextAlignment="Center"/>
                                     </Border>
                                     <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                         <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                         <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Grid>
                             </Border>

                            <!-- FINAL -->
                            <TextBlock Text="&#x1F3C6;  FINAL" FontSize="16" FontWeight="ExtraBold"
                                       Foreground="#FFD700" FontFamily="Segoe UI" Margin="0,28,0,16"/>
                            <Border CornerRadius="16" Padding="24,16" Margin="0,0,0,8" 
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding FinalMatch, Converter={StaticResource NullToVis}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A2238" Offset="0"/>
                                        <GradientStop Color="#1E293B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FFD700" Opacity="0.3"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Grid DataContext="{Binding FinalMatch}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding HomeTeam.Name}" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                         <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="32" Height="32" Margin="15,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                     </StackPanel>
                                     <Border Grid.Column="1" Background="#0F172A" CornerRadius="12" Padding="14,6" HorizontalAlignment="Center">
                                         <TextBlock Text="{Binding ScoreDisplay}" Foreground="#FFD700" FontSize="20" FontWeight="Black" TextAlignment="Center"/>
                                     </Border>
                                     <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                         <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogoPathConverter}}" Width="32" Height="32" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                         <TextBlock Text="{Binding AwayTeam.Name}" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Grid>
                             </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
