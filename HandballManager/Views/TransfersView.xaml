<UserControl x:Class="HandballManager.Views.TransfersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="40,30">
        <StackPanel>
            <TextBlock Text="TRANSFERS" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560"
                       FontFamily="Segoe UI" Margin="4,0,0,10"/>
            <TextBlock Text="Transfer Centre" FontSize="36" FontWeight="Black" Foreground="White"
                       FontFamily="Segoe UI" Margin="0,0,0,24"/>

            <TabControl Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" 
                            Background="Transparent" 
                            CornerRadius="10,10,0,0"
                            Padding="20,10"
                            Margin="0,0,4,0"
                            Cursor="Hand">
                                        <TextBlock x:Name="TabText"
                                   Text="{TemplateBinding Header}"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="ExtraBold"
                                   Foreground="#8888AA"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#16213E"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E94560"/>
                                            <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,3,0,0"/>
                                            <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabText" Property="Foreground" Value="#CCCCEE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="TabControl">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <StackPanel>
                                        <!-- Tab strip -->
                                        <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="8,8,8,0">
                                            <TabPanel IsItemsHost="True" Background="Transparent"/>
                                        </Border>
                                        <!-- Content area -->
                                        <Border Background="Transparent">
                                            <ContentPresenter ContentSource="SelectedContent"/>
                                        </Border>
                                    </StackPanel>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  TAB 1 — Incoming Offers                          -->
                <!-- ══════════════════════════════════════════════════ -->
                <TabItem Header="INCOMING OFFERS">
                    <StackPanel Margin="0,16,0,0">
                        <Border CornerRadius="20" Background="#16213E" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="40" Opacity="0.2" ShadowDepth="10"/>
                            </Border.Effect>
                            <DataGrid ItemsSource="{Binding Offers}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      BorderThickness="0"
                                      FontFamily="Segoe UI"
                                      FontSize="14"
                                      Foreground="White"
                                      ColumnHeaderHeight="45"
                                      RowHeight="52"
                                      HeadersVisibility="Column">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="Foreground"      Value="#A0A8C0"/>
                                        <Setter Property="FontWeight"      Value="ExtraBold"/>
                                        <Setter Property="FontSize"        Value="11"/>
                                        <Setter Property="FontFamily"      Value="Segoe UI"/>
                                        <Setter Property="Padding"         Value="15,0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                        <Setter Property="BorderBrush"     Value="#2A2A4A"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush"     Value="#1E1E3A"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A2238"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding"           Value="15,0"/>
                                        <Setter Property="BorderThickness"   Value="0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="PLAYER" Width="*" MinWidth="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="👤" Foreground="#666688" Margin="0,0,10,0" FontSize="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PlayerName}" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="FROM CLUB" Binding="{Binding FromTeamName}" Width="*" MinWidth="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="TYPE" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="#1A2238">
                                                    <TextBlock Text="{Binding OfferType}" Foreground="#38BDF8" FontWeight="Bold"
                                                               FontFamily="Segoe UI" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="FEE" Binding="{Binding OfferAmountText}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="FontWeight"          Value="Bold"/>
                                                <Setter Property="Foreground"          Value="White"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="WAGE" Binding="{Binding ProposedWageText}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="YRS" Binding="{Binding ProposedYears}" Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Foreground"          Value="#666688"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Button Content="ACCEPT"
                                                            Command="{Binding DataContext.AcceptOfferCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding Id}"
                                                            Cursor="Hand" Margin="0,0,8,0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="#22c55e" CornerRadius="10" Padding="16,8">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                                               FontWeight="Black" FontFamily="Segoe UI" FontSize="12"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Content="REJECT"
                                                            Command="{Binding DataContext.RejectOfferCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding Id}"
                                                            Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="#E94560" CornerRadius="10" Padding="16,8">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                                               FontWeight="Black" FontFamily="Segoe UI" FontSize="12"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <TextBlock Text="No incoming offers." Foreground="#666688" FontStyle="Italic"
                                   FontFamily="Segoe UI" Margin="8,16,0,0"
                                   Visibility="{Binding HasNoOffers, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </TabItem>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  TAB 2 — Free Agents                              -->
                <!-- ══════════════════════════════════════════════════ -->
                <TabItem Header="FREE AGENTS">
                    <StackPanel Margin="0,16,0,0">
                        <Border CornerRadius="20" Background="#16213E" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="40" Opacity="0.2" ShadowDepth="10"/>
                            </Border.Effect>
                            <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar">
                                        <Setter Property="Width" Value="6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Grid>
                                                        <Border Background="#1E1E3A" CornerRadius="3" Width="6" HorizontalAlignment="Center"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border Background="#E94560" CornerRadius="3" Width="6"/>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ScrollViewer.Resources>
                                <DataGrid ItemsSource="{Binding FreeAgents}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      BorderThickness="0"
                                      FontFamily="Segoe UI"
                                      FontSize="14"
                                      Foreground="White"
                                      ColumnHeaderHeight="45"
                                      RowHeight="52"
                                      HeadersVisibility="Column">

                                    <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="Foreground"      Value="#A0A8C0"/>
                                        <Setter Property="FontWeight"      Value="ExtraBold"/>
                                        <Setter Property="FontSize"        Value="11"/>
                                        <Setter Property="FontFamily"      Value="Segoe UI"/>
                                        <Setter Property="Padding"         Value="15,0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                        <Setter Property="BorderBrush"     Value="#2A2A4A"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush"     Value="#1E1E3A"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A2238"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding"           Value="15,0"/>
                                        <Setter Property="BorderThickness"   Value="0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="PLAYER" Width="*" MinWidth="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="👤" Foreground="#666688" Margin="0,0,10,0" FontSize="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="POS" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="#1A2238">
                                                    <TextBlock Text="{Binding Position}" Foreground="#38BDF8" FontWeight="Bold"
                                                               FontFamily="Segoe UI" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="65">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="OVR" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="#38BDF820">
                                                    <TextBlock Text="{Binding Overall}" Foreground="#38BDF8" FontWeight="Black"
                                                               FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="NATIONALITY" Binding="{Binding Nationality}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Foreground"          Value="#A0A8C0"/>
                                                <Setter Property="FontFamily"          Value="Segoe UI"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="SIGN"
                                                        Command="{Binding DataContext.SignFreeAgentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding Id}"
                                                        Cursor="Hand" HorizontalAlignment="Right">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="#E94560" CornerRadius="10" Padding="16,8">
                                                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                                           FontWeight="Black" FontFamily="Segoe UI" FontSize="12"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Text="No free agents available." Foreground="#666688" FontStyle="Italic"
                                   FontFamily="Segoe UI" Margin="8,16,0,0"
                                   Visibility="{Binding HasNoFreeAgents, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </TabItem>

            </TabControl>
        </StackPanel>
    </Grid>
</UserControl>
