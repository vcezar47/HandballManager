<UserControl x:Class="HandballManager.Views.PlayerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <converters:AttributeColorConverter x:Key="AttrColorConverter"/>
        <converters:AttributeHighlightConverter x:Key="AttrHighlightConverter"/>
        <converters:ProgressionPhaseToIconConverter x:Key="PhaseIconConverter"/>
        <converters:ProgressionPhaseToVisibilityConverter x:Key="PhaseVisConverter"/>
        <converters:AttributeTrendToIconConverter x:Key="AttrTrendIconConverter"/>
        <converters:AttributeTrendToVisibilityConverter x:Key="AttrTrendVisConverter"/>
        <converters:NationalityToFlagConverter x:Key="NationalityToFlag"/>
        
        <Style x:Key="AttributeLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A8C0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="AttributeValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatGroupHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E94560"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="AttributeContainer" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style x:Key="TrendArrow" TargetType="Image">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Name, Basic Info -->
        <Border Grid.Row="0" Background="#16213E" Padding="20" CornerRadius="12" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="👤" FontSize="48" Margin="0,0,20,0" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1A2238" CornerRadius="10" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Player.ShirtNumber, StringFormat=# {0}}" Foreground="#A0A8C0" FontWeight="Black" FontSize="14"/>
                        </Border>
                        <TextBlock Text="{Binding Player.Name}" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Border CornerRadius="3" ClipToBounds="True" Width="22" Height="15" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Image Source="{Binding Player.Nationality, Converter={StaticResource NationalityToFlag}}" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="{Binding Player.Nationality}" Foreground="#A0A8C0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Player.Position}" Foreground="#E94560" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text=" • " Foreground="#444466" FontSize="16"/>
                        <TextBlock Text="{Binding Player.Age, StringFormat='{}{0} years old'}" Foreground="#A0A8C0" FontSize="14"/>
                        <TextBlock Text=" • " Foreground="#444466" FontSize="16"/>
                        <TextBlock Text="{Binding Player.Birthdate, StringFormat='Born: {0:yyyy-MM-dd}'}" Foreground="#A0A8C0" FontSize="14"/>
                        <TextBlock Text=" • " Foreground="#444466" FontSize="16"/>
                        <TextBlock Text="{Binding Player.Height, StringFormat='{}{0} cm'}" Foreground="#A0A8C0" FontSize="14"/>
                        <TextBlock Text=" • " Foreground="#444466" FontSize="16"/>
                        <TextBlock Text="{Binding Player.Weight, StringFormat='{}{0} kg'}" Foreground="#A0A8C0" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="#E94560" Padding="15,5" CornerRadius="20">
                            <TextBlock Text="{Binding Masked.Overall100, StringFormat='OVR {0}'}" Foreground="White" FontWeight="Bold" FontSize="20"/>
                        </Border>
                    </StackPanel>
                    <Border Background="#162A46" Padding="12,4" CornerRadius="16" HorizontalAlignment="Right" Margin="0,10,0,0" BorderBrush="#1E3A5F" BorderThickness="1">
                        <TextBlock Text="{Binding Masked.BuyoutFeeLabel}" Foreground="#38BDF8" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <Border Background="#162A46" Padding="12,4" CornerRadius="16" HorizontalAlignment="Right" Margin="0,5,0,0" BorderBrush="#1E3A5F" BorderThickness="1">
                        <TextBlock Text="{Binding Player.WeeklyWage, StringFormat='Wage: {0:N0} €/pw'}" Foreground="#34D399" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <Border Background="#1A2238" Padding="12,4" CornerRadius="16" HorizontalAlignment="Right" Margin="0,5,0,0" BorderBrush="#2A3248" BorderThickness="1">
                        <TextBlock Text="{Binding Player.ContractEndDate, StringFormat='Expires: {0:MMM yyyy}'}" Foreground="#A0A8C0" FontWeight="Bold" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats Summary Section -->
        <Border Grid.Row="1" Background="#1A2238" Padding="15" CornerRadius="12" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Season -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CURRENT SEASON" Foreground="#E94560" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Matches" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.MatchesPlayed}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Avg Rating" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.AverageRating, StringFormat={}{0:F2}}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Goals / Assists" Foreground="#A0A8C0" FontSize="11"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Player.SeasonGoals}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text=" / " Foreground="#444466" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Player.SeasonAssists}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Saves" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.SeasonSaves}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="#2A3248" Margin="20,5"/>

                <!-- Last Season -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="LAST SEASON" Foreground="#A0A8C0" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Matches" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.LastSeasonMatchesPlayed}" Foreground="#E0E0E0" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Avg Rating" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.LastSeasonAverageRating, StringFormat={}{0:F2}}" Foreground="#E0E0E0" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="G / A" Foreground="#A0A8C0" FontSize="11"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Player.LastSeasonGoals}" Foreground="#E0E0E0" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text=" / " Foreground="#444466" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Player.LastSeasonAssists}" Foreground="#E0E0E0" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Saves" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.LastSeasonSaves}" Foreground="#E0E0E0" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="#2A3248" Margin="20,5"/>

                <!-- Career -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="CAREER TOTALS" Foreground="#38BDF8" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Matches" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.CareerMatchesPlayed}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Goals" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.CareerGoals}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Assists" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.CareerAssists}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Saves" Foreground="#A0A8C0" FontSize="11"/>
                            <TextBlock Text="{Binding Player.CareerSaves}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats Grid -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Technical Column -->
            <Border Grid.Column="0" Style="{StaticResource AttributeContainer}">
                <Grid>
                    <!-- Outfield Tech -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Player.Position}" Value="GK">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <TextBlock Text="TECHNICAL" Style="{StaticResource StatGroupHeader}"/>

                        <!-- Dribbling -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Dribbling"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Dribbling" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Dribbling}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Dribbling}"/>
                                    <TextBlock Text="{Binding Masked.Dribbling}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Dribbling, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Finishing -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Finishing"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Finishing" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Finishing}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Finishing}"/>
                                    <TextBlock Text="{Binding Masked.Finishing}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Finishing, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- First Touch -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="First Touch"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="First Touch" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Receiving}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Receiving}"/>
                                    <TextBlock Text="{Binding Masked.Receiving}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Receiving, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Long Throws -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Long Throws"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Long Throws" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=LongThrows}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=LongThrows}"/>
                                    <TextBlock Text="{Binding Masked.LongThrows}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.LongThrows, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Marking -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Marking"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Marking" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Marking}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Marking}"/>
                                    <TextBlock Text="{Binding Masked.Marking}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Marking, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Passing -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Passing"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Passing" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Passing}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Passing}"/>
                                    <TextBlock Text="{Binding Masked.Passing}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Passing, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 7m Taking -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="7m Taking"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="7m Taking" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=SevenMeterTaking}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=SevenMeterTaking}"/>
                                    <TextBlock Text="{Binding Masked.SevenMeterTaking}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.SevenMeterTaking, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Tackling -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Tackling"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Tackling" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Tackling}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Tackling}"/>
                                    <TextBlock Text="{Binding Masked.Tackling}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Tackling, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Technique -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Technique"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Technique" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Technique}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Technique}"/>
                                    <TextBlock Text="{Binding Masked.Technique}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Technique, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- GK Tech (Goalkeeping) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Player.Position}" Value="GK">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="GOALKEEPING" Style="{StaticResource StatGroupHeader}"/>

                        <!-- Aerial Reach -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Aerial Reach"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Aerial Reach" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=AerialReach}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=AerialReach}"/>
                                    <TextBlock Text="{Binding Masked.AerialReach}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.AerialReach, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Communication -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Communication"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Communication" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Communication}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Communication}"/>
                                    <TextBlock Text="{Binding Masked.Communication}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Communication, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Eccentricity -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Eccentricity"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Eccentricity" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Eccentricity}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Eccentricity}"/>
                                    <TextBlock Text="{Binding Masked.Eccentricity}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Eccentricity, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Handling -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Handling"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Handling" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Handling}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Handling}"/>
                                    <TextBlock Text="{Binding Masked.Handling}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Handling, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Passing (GK) -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Passing"/>
                                </MultiBinding>
                            </Border.Background>
                            <Grid Margin="5,2">
                                <TextBlock Text="Passing" Style="{StaticResource AttributeLabel}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image Style="{StaticResource TrendArrow}"
                                           Source="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendIconConverter}, ConverterParameter=Passing}"
                                           Visibility="{Binding Player.SeasonAttributeChangesJson, Converter={StaticResource AttrTrendVisConverter}, ConverterParameter=Passing}"/>
                                    <TextBlock Text="{Binding Masked.Passing}" Style="{StaticResource AttributeValue}" Foreground="{Binding Player.Passing, Converter={StaticResource AttrColorConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Receiving (GK) -->
                        <Border Margin="0,1" CornerRadius="4">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource AttrHighlightConverter}">
                                    <Binding Path="Player.Position"/>
                                    <Binding Source="Receiving"/>
