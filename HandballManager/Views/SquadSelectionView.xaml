<UserControl x:Class="HandballManager.Views.SquadSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HandballManager.ViewModels"
             xmlns:conv="clr-namespace:HandballManager.Converters"
             Background="#1A1A2E">

    <UserControl.Resources>
        <conv:TeamLogoPathConverter x:Key="LogoConverter"/>
        <!-- Slot Button Style -->
        <Style x:Key="SlotButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A2238"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Player Row Button Style -->
        <Style x:Key="PlayerListButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Tab Toggle Button Style -->
        <Style x:Key="TabToggleStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#A0A8C0"/>
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Court/Pool -->
            <RowDefinition Height="Auto"/> <!-- Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- Match Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding UserTeamLogo, Converter={StaticResource LogoConverter}}" Width="48" Height="48" Margin="0,0,16,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SQUAD SELECTION" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding MatchInfo}" FontSize="24" FontWeight="Black" Foreground="White" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="AUTO-PICK BEST SQUAD" Command="{Binding AutoPickCommand}" 
                        Background="#334155" Foreground="White" FontSize="12" FontWeight="Bold" 
                        Padding="16,10" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#475569"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="CLEAR ALL" Command="{Binding ClearAllCommand}" 
                        Background="#16213E" Foreground="#A0A8C0" FontSize="12" FontWeight="Bold" 
                        Padding="16,10" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#1E293B"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>



        <!-- Dynamic Content Area -->        <!-- Dynamic Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Court Visualization of Slots -->
            <Border Grid.Column="0" Background="#16213E" CornerRadius="16" Padding="24">
                <Grid>
                    <ItemsControl ItemsSource="{Binding StartingLineupSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SlotButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#E94560"/>
                                                    <Setter Property="Background" Value="#252D45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <!-- Grid layout: text left, shirt right -->
                                    <Grid HorizontalAlignment="Stretch">
                                        <!-- State 1: EMPTY -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding Player, Converter={StaticResource NullToVis}, ConverterParameter='Invert'}">
                                            <TextBlock Text="{Binding Position}" Foreground="#3A4A6A" FontSize="18" FontWeight="Black"/>
                                        </StackPanel>

                                        <!-- State 2: FILLED -->
                                        <Grid Visibility="{Binding Player, Converter={StaticResource NullToVis}}" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: position label + player name + overall -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Position}" Foreground="#E94560" FontSize="11" FontWeight="ExtraBold" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Player.Name}" 
                                                           Foreground="White" 
                                                           FontSize="15" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Player.Overall100, StringFormat='{}⭐ {0}'}" 
                                                           Foreground="#A0A8C0" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Right: shirt number circle -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <Border Width="38" Height="38" CornerRadius="19" Background="#1E293B" BorderBrush="#38BDF8" BorderThickness="2">
                                                    <TextBlock Text="{Binding Player.ShirtNumber}" Foreground="White"
                                                               FontSize="14" FontWeight="Black" FontFamily="Segoe UI"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Grid>

                                        <!-- Clear button overlaid top-right -->
                                        <Button Width="18" Height="18"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                                Background="#334155" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                                Visibility="{Binding Player, Converter={StaticResource NullToVis}}"
                                                Command="{Binding DataContext.ClearSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9">
                                                        <TextBlock Text="×" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#E94560"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- RIGHT: Subs & Player Pool -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Substitutes Section — fixed 9 slots -->
                <TextBlock Grid.Row="0" Text="BENCH (click empty slot then pick player below)" 
                           FontSize="12" FontWeight="Black" Foreground="White" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Background="#16213E" CornerRadius="12" Padding="10">
                        <ItemsControl ItemsSource="{Binding SubstituteSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each sub slot is clickable -->
                                <Button Command="{Binding DataContext.SelectSubSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,0,3" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="#1A2238" CornerRadius="7" Padding="10,7"
                                                    BorderThickness="1.5" BorderBrush="#2A2A4A">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="42"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="45"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Fixed Position Label -->
                                                    <Border Grid.Column="0" Background="#1E2A4A" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" Width="38">
                                                        <TextBlock Text="{Binding DisplayLabel}" Foreground="#E94560"
                                                                   FontSize="10" FontWeight="ExtraBold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    
                                                    <!-- Centered/Left-aligned Name -->
                                                    <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                               FontFamily="Segoe UI" FontSize="14" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Player.Name}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                        <Setter Property="Text" Value="Empty"/>
                                                                        <Setter Property="Foreground" Value="#3A4A6A"/>
                                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    
                                                    <!-- Fixed Overall -->
                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding Player.Overall100, StringFormat='⭐{0}'}"
                                                               Foreground="#A0A8C0" FontSize="11" FontWeight="Bold"
                                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                                               Visibility="{Binding Player, Converter={StaticResource NullToVis}}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#38BDF8"/>
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A2A3A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2A3A5A"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#475569"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                </ScrollViewer>

                <!-- Pool Section -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,12" VerticalAlignment="Center">
                    <TextBlock Text="AVAILABLE PLAYERS" FontSize="13" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                    
                    <!-- Starter Slot Helper -->
                    <TextBlock Foreground="#38BDF8" FontWeight="Bold" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSlot}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text=" (Assign starter to: "/><Run Text="{Binding ActiveSlot.Position, Mode=OneWay}"/><Run Text=")"/>
                    </TextBlock>
                    
                    <!-- Bench Slot Helper -->
                    <TextBlock Foreground="#E94560" FontWeight="Bold" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding ActiveSubSlot, Converter={StaticResource NullToVis}}">
                        <Run Text=" (Assign bench to: "/><Run Text="{Binding ActiveSubSlot.Position, Mode=OneWay}"/><Run Text=")"/>
                    </TextBlock>
                    
                    <!-- Global Hint -->
                    <TextBlock Text=" ← select a slot above first" Foreground="#94A3B8" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ActiveSlot}" Value="{x:Null}"/>
                                            <Condition Binding="{Binding ActiveSubSlot}" Value="{x:Null}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="4" Background="#16213E" CornerRadius="12" Padding="12">
                    <ListBox ItemsSource="{Binding AvailablePlayers}" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Single click to assign to active slot (starter or sub) -->
                                <Button Style="{StaticResource PlayerListButtonStyle}"
                                        Command="{Binding DataContext.AssignPlayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Position}" Foreground="#E94560" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Overall100, StringFormat='{}⭐ {0}'}" Foreground="#A0A8C0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="16" Padding="20" Margin="0,24,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="SIMULATE MATCH" Command="{Binding SimulateGameCommand}" 
                        IsEnabled="{Binding IsSquadValid}"
                        Foreground="#A0A8C0" FontSize="16" FontWeight="Black" Padding="30,16" BorderThickness="1" BorderBrush="#2D3B55" Cursor="Hand" Margin="0,0,12,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8" Background="#1A2238" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#252D45"/></Trigger>
                                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.4"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="⚡ ENTER THE ARENA" Command="{Binding EnterTheArenaCommand}" 
                        IsEnabled="{Binding IsSquadValid}"
                        Foreground="White" FontSize="16" FontWeight="Black" Padding="40,16" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="8">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#E94560" Offset="0"/>
                                                    <GradientStop Color="#C73652" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FF536E"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                
                <StackPanel VerticalAlignment="Center" Margin="24,0,0,0" Visibility="{Binding IsSquadValid, Converter={StaticResource BoolToVis}, ConverterParameter='Invert'}">
                    <TextBlock Text="Squad is not complete!" Foreground="#F59E0B" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Text="Assign 7 starters and at least 7 substitutes." Foreground="#A0A8C0" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
