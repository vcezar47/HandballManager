<UserControl x:Class="HandballManager.Views.YouthDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HandballManager.Converters">
    <UserControl.Resources>
        <conv:AttributeColorConverter x:Key="AttrColor"/>
        <conv:NationalityToFlagConverter x:Key="NationalityToFlag"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#E94560"/>
            <Setter Property="FontWeight"  Value="ExtraBold"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>
        <Style x:Key="AttrLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#A0A8C0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="AttrValue" TargetType="TextBlock">
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style x:Key="AttrRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"    Value="#16213E"/>
            <Setter Property="CornerRadius"  Value="12"/>
            <Setter Property="Padding"       Value="16"/>
            <Setter Property="Margin"        Value="5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="30,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Back button -->
            <Button Grid.Row="0" Content="← Back to intake" HorizontalAlignment="Left"
                    Command="{Binding BackCommand}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Foreground="#666688" FontSize="13" Margin="0,0,0,16">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Header card -->
            <Border Grid.Row="1" Background="#16213E" CornerRadius="14" Padding="24,20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🌟" FontSize="52" Margin="0,0,20,0" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="YOUTH PROSPECT" FontSize="11" FontWeight="ExtraBold" Foreground="#E94560" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Name}" FontSize="30" FontWeight="Black" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="#1E2A4A" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Position}" Foreground="#A0A8C0" FontWeight="Bold" FontSize="13"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Border CornerRadius="2" ClipToBounds="True" Width="20" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Image Source="{Binding Nationality, Converter={StaticResource NationalityToFlag}}" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding Nationality}" Foreground="#666688" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Age, StringFormat='{}{0} yrs'}" Foreground="#666688" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding Height, StringFormat='{}{0} cm'}" Foreground="#666688" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding Weight, StringFormat='{}{0} kg'}" Foreground="#666688" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Border Background="#E94560" Padding="18,6" CornerRadius="20" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <TextBlock Text="{Binding Overall, StringFormat='OVR {0}'}" Foreground="White" FontWeight="Black" FontSize="20"/>
                        </Border>
                        <Button Content="✍  Sign Player" Command="{Binding SignCommand}"
                                Background="#22c55e" Foreground="White" FontWeight="Bold"
                                FontSize="14" Padding="20,10" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#16a34a"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Attributes grid -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Technical -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TECHNICAL" Style="{StaticResource SectionHeader}"/>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dribbling" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Dribbling}" Style="{StaticResource AttrValue}" Foreground="{Binding Dribbling, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Finishing" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Finishing}" Style="{StaticResource AttrValue}" Foreground="{Binding Finishing, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Marking" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Marking}" Style="{StaticResource AttrValue}" Foreground="{Binding Marking, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Passing" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Passing}" Style="{StaticResource AttrValue}" Foreground="{Binding Passing, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Technique" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Technique}" Style="{StaticResource AttrValue}" Foreground="{Binding Technique, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Receiving" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Receiving}" Style="{StaticResource AttrValue}" Foreground="{Binding Receiving, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Long throws" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding LongThrows}" Style="{StaticResource AttrValue}" Foreground="{Binding LongThrows, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="7m Taking" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SevenMeterTaking}" Style="{StaticResource AttrValue}" Foreground="{Binding SevenMeterTaking, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tackling" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Tackling}" Style="{StaticResource AttrValue}" Foreground="{Binding Tackling, Converter={StaticResource AttrColor}}"/>
                        </Grid>

                        <!-- GK Technical -->
                        <TextBlock Text="GOALKEEPING" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"
                                   Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}"/>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Reflexes" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Reflexes}" Style="{StaticResource AttrValue}" Foreground="{Binding Reflexes, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Handling" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Handling}" Style="{StaticResource AttrValue}" Foreground="{Binding Handling, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="1v1s" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding OneOnOnes}" Style="{StaticResource AttrValue}" Foreground="{Binding OneOnOnes, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Aerial reach" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding AerialReach}" Style="{StaticResource AttrValue}" Foreground="{Binding AerialReach, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Throwing" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Throwing}" Style="{StaticResource AttrValue}" Foreground="{Binding Throwing, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Communication" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Communication}" Style="{StaticResource AttrValue}" Foreground="{Binding Communication, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}" Visibility="{Binding IsGoalkeeper, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Eccentricity" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Eccentricity}" Style="{StaticResource AttrValue}" Foreground="{Binding Eccentricity, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Physical -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PHYSICAL" Style="{StaticResource SectionHeader}"/>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Acceleration" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Acceleration}" Style="{StaticResource AttrValue}" Foreground="{Binding Acceleration, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Pace" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Pace}" Style="{StaticResource AttrValue}" Foreground="{Binding Pace, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stamina" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Stamina}" Style="{StaticResource AttrValue}" Foreground="{Binding Stamina, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Strength" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Strength}" Style="{StaticResource AttrValue}" Foreground="{Binding Strength, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Agility" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Agility}" Style="{StaticResource AttrValue}" Foreground="{Binding Agility, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Balance" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Balance}" Style="{StaticResource AttrValue}" Foreground="{Binding Balance, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Jumping reach" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding JumpingReach}" Style="{StaticResource AttrValue}" Foreground="{Binding JumpingReach, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Natural fitness" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding NaturalFitness}" Style="{StaticResource AttrValue}" Foreground="{Binding NaturalFitness, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mental -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="MENTAL" Style="{StaticResource SectionHeader}"/>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Aggression" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Aggression}" Style="{StaticResource AttrValue}" Foreground="{Binding Aggression, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Anticipation" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Anticipation}" Style="{StaticResource AttrValue}" Foreground="{Binding Anticipation, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Composure" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Composure}" Style="{StaticResource AttrValue}" Foreground="{Binding Composure, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Concentration" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Concentration}" Style="{StaticResource AttrValue}" Foreground="{Binding Concentration, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Decisions" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Decisions}" Style="{StaticResource AttrValue}" Foreground="{Binding Decisions, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Determination" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Determination}" Style="{StaticResource AttrValue}" Foreground="{Binding Determination, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Flair" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Flair}" Style="{StaticResource AttrValue}" Foreground="{Binding Flair, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Leadership" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Leadership}" Style="{StaticResource AttrValue}" Foreground="{Binding Leadership, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Off the ball" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding OffTheBall}" Style="{StaticResource AttrValue}" Foreground="{Binding OffTheBall, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Positioning" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Positioning}" Style="{StaticResource AttrValue}" Foreground="{Binding Positioning, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Teamwork" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Teamwork}" Style="{StaticResource AttrValue}" Foreground="{Binding Teamwork, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                        <Grid Style="{StaticResource AttrRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vision" Style="{StaticResource AttrLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Vision}" Style="{StaticResource AttrValue}" Foreground="{Binding Vision, Converter={StaticResource AttrColor}}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
