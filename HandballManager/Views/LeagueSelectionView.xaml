<UserControl x:Class="HandballManager.Views.LeagueSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:HandballManager.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:StartViewModel}">
    <!-- Outer margin and padding trimmed so the button is never clipped at 720px window height -->
    <Border CornerRadius="20" Margin="40,16" Padding="40,24"
            MaxWidth="900" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A2238" Offset="0"/>
                <GradientStop Color="#16213E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <!-- Removed outer drop shadow as it was creating glow on logo above -->
        <!-- Individual cards inside already have their own shadow effects -->

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="CHOOSE YOUR COMPETITION" Foreground="#E94560" HorizontalAlignment="Center"
                       FontWeight="ExtraBold" FontSize="12" Margin="0,0,0,24"/>

            <Grid HorizontalAlignment="Center" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Arrow -->
                <Button Grid.Column="0" Command="{Binding MoveToPreviousLeagueCommand}"
                        VerticalAlignment="Center" Margin="0,0,20,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="◀" FontSize="40" Foreground="#E94560" Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- League Card -->
                <ContentControl Grid.Column="1" Content="{Binding SelectedLeague}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <Border x:Name="LeagueCard" Background="#1E2A4A" CornerRadius="20" Width="320" Padding="30">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E94560" Offset="0"/>
                                        <GradientStop Color="#C73652" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="25" Opacity="0.4" Color="#E94560" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="{Binding Logo}" Height="140" Margin="0,0,0,20" 
                                           HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="28" FontWeight="Black" 
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Country}" Foreground="#E94560" FontSize="16" FontWeight="Bold" 
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Right Arrow -->
                <Button Grid.Column="2" Command="{Binding MoveToNextLeagueCommand}"
                        VerticalAlignment="Center" Margin="20,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="▶" FontSize="40" Foreground="#E94560" Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Button top margin reduced from 50 → 20 -->
            <Button Content="CONTINUE TO TEAM SELECTION" Command="{Binding SelectLeagueCommand}"
                    Margin="0,20,0,0" Width="300" Height="50"
                    Foreground="White" FontSize="13" FontWeight="Black"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="25">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#E94560" Offset="0"/>
                                                <GradientStop Color="#C73652" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#FF536E" Offset="0"/>
                                                        <GradientStop Color="#E94560" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
