<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HandballManager.Mobile"
             x:Class="HandballManager.Mobile.WorldLeaguesPage"
             x:Name="Page"
             Title="WORLD LEAGUES"
             BackgroundColor="#1A1A2E">

    <ContentPage.Resources>
        <local:TeamLogoSourceConverter x:Key="TeamLogo" />
        <local:AssetImageSourceConverter x:Key="AssetImage" />
        <local:IsNullConverter x:Key="IsNull" />
        <local:CompetitionHighlightConverter x:Key="CompetitionHighlight" />

        <Style x:Key="CountryTab" TargetType="Border">
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="12">

            <!-- Country tabs -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding AvailableCompetitions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CountryTab}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BindingContext.SelectCompetitionCommand, Source={x:Reference Page}}" CommandParameter="{Binding Name}" />
                                </Border.GestureRecognizers>
                                <Border.Stroke>
                                    <MultiBinding Converter="{StaticResource CompetitionHighlight}">
                                        <Binding Path="Name" />
                                        <Binding Path="BindingContext.SelectedCompetition" Source="{x:Reference Page}" />
                                    </MultiBinding>
                                </Border.Stroke>
                                <Border.BackgroundColor>
                                    <MultiBinding Converter="{StaticResource CompetitionHighlight}" ConverterParameter="background">
                                        <Binding Path="Name" />
                                        <Binding Path="BindingContext.SelectedCompetition" Source="{x:Reference Page}" />
                                    </MultiBinding>
                                </Border.BackgroundColor>
                                <HorizontalStackLayout Spacing="7">
                                    <Image Source="{Binding Flag, Converter={StaticResource AssetImage}}" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Label Text="{Binding Country}" FontFamily="OpenSansSemibold" FontSize="13" VerticalOptions="Center">
                                        <Label.TextColor>
                                            <MultiBinding Converter="{StaticResource CompetitionHighlight}" ConverterParameter="text">
                                                <Binding Path="Name" />
                                                <Binding Path="BindingContext.SelectedCompetition" Source="{x:Reference Page}" />
                                            </MultiBinding>
                                        </Label.TextColor>
                                    </Label>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- League card -->
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="14,12">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <HorizontalStackLayout Grid.Column="0" Spacing="10">
                            <Image Source="{Binding LeagueLogoPath, Converter={StaticResource AssetImage}}" WidthRequest="24" HeightRequest="24" Aspect="AspectFit" VerticalOptions="Center" />
                            <Label Text="{Binding LeagueDisplayName}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="16" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="HISTORY" TextColor="#8888AA" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewLeagueHistoryCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Grid ColumnDefinitions="26,22,*,30,34,36" ColumnSpacing="4">
                        <Label Grid.Column="0" Text="#" TextColor="#A0A8C0" FontSize="10" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="CLUB" TextColor="#A0A8C0" FontSize="10" FontFamily="OpenSansSemibold" />
                        <Label Grid.Column="3" Text="P" TextColor="#A0A8C0" FontSize="10" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="4" Text="GD" TextColor="#A0A8C0" FontSize="10" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="5" Text="PTS" TextColor="#A0A8C0" FontSize="10" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#2A2A4A" Margin="0,-6,0,0" />

                    <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding Standings}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="26,22,*,30,34,36" ColumnSpacing="4" Padding="0,7">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.ViewTeamCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="{Binding Rank}" TextColor="#666688" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Image Grid.Column="1" Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogo}}" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Team.Name}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <Label Grid.Column="3" Text="{Binding Played}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="4" Text="{Binding GoalDifference}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="5" Text="{Binding Points}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Cup group card -->
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="14,12">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewCupDetailCommand}" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image Source="{Binding CupLogoPath, Converter={StaticResource AssetImage}}" WidthRequest="24" HeightRequest="24" Aspect="AspectFit" VerticalOptions="Center" />
                        <Label Text="{Binding CupGroupTitle}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="16" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                        <Label Text="›" TextColor="#666688" FontFamily="OpenSansSemibold" FontSize="16" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Text="Cup draw not yet available." TextColor="#555577" FontSize="13" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,8"
                           IsVisible="{Binding PlayerCupGroup, Converter={StaticResource IsNull}}" />

                    <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding PlayerCupGroup.Entries}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="26,22,*,30,34,36" ColumnSpacing="4" Padding="0,7">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.ViewCupTeamCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="{Binding Rank}" TextColor="#666688" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Image Grid.Column="1" Source="{Binding Team.LogoPath, Converter={StaticResource TeamLogo}}" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Team.Name}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <Label Grid.Column="3" Text="{Binding Played}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="4" Text="{Binding GoalDifference}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="5" Text="{Binding Points}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Supercup fixtures (Romania & Denmark) -->
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="14,12" x:Name="SupercupCard">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewSupercupDetailCommand}" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image x:Name="SupercupLogo" WidthRequest="24" HeightRequest="24" Aspect="AspectFit" VerticalOptions="Center" />
                        <Label x:Name="SupercupTitle" Text="Supercupa României" TextColor="White" FontFamily="OpenSansSemibold" FontSize="16" VerticalOptions="Center" />
                        <Label Text="›" TextColor="#666688" FontFamily="OpenSansSemibold" FontSize="16" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="6" BindableLayout.ItemsSource="{Binding SupercupFixtures}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#1A2238" Stroke="#252D45" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,8">
                                    <Grid ColumnDefinitions="*,64,*" ColumnSpacing="4">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="6" HorizontalOptions="End" VerticalOptions="Center">
                                            <Label Text="{Binding HomeTeam.Name}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="11" LineBreakMode="TailTruncation" VerticalOptions="Center" HorizontalTextAlignment="End" />
                                            <Image Source="{Binding HomeTeam.LogoPath, Converter={StaticResource TeamLogo}}" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding ScoreDisplay}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="13" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                        <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                            <Image Source="{Binding AwayTeam.LogoPath, Converter={StaticResource TeamLogo}}" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                            <Label Text="{Binding AwayTeam.Name}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="11" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
