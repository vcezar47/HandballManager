<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HandballManager.Mobile.YouthDetailPage"
             Title="PROSPECT"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="12">

            <!-- Header -->
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,12">
                <Grid ColumnDefinitions="44,*,64" ColumnSpacing="10">
                    <Image Grid.Column="0" Source="youth_stars.png" WidthRequest="40" HeightRequest="40" Aspect="AspectFit" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="{Binding Name}" TextColor="#EAEAEA" FontFamily="OpenSansSemibold" FontSize="20" LineBreakMode="WordWrap" />
                        <Label TextColor="#8888AA" FontSize="13">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Position}" TextColor="#E94560" FontFamily="OpenSansSemibold" />
                                    <Span Text="  ·  " /><Span Text="{Binding Age}" /><Span Text=" yrs" />
                                    <Span Text="  ·  " /><Span Text="{Binding Nationality}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label TextColor="#8888AA" FontSize="13">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Height}" /><Span Text=" cm  ·  " />
                                    <Span Text="{Binding Weight}" /><Span Text=" kg" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
                        <Label Text="{Binding Overall}" TextColor="#F0A500" FontFamily="OpenSansSemibold" FontSize="30" HorizontalTextAlignment="Center" />
                        <Label Text="RATED" TextColor="#8888AA" FontSize="9" CharacterSpacing="1" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Button Text="OFFER FIRST-TEAM CONTRACT"
                    BackgroundColor="#E94560" TextColor="White" FontFamily="OpenSansSemibold" CornerRadius="10" HeightRequest="48"
                    Command="{Binding SignCommand}" />

            <!-- Attribute sections (grids injected from code-behind) -->
            <Label Text="TECHNICAL" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="2" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,10">
                <ContentView x:Name="TechnicalHost" />
            </Border>

            <Label Text="MENTAL" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="2" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,10">
                <ContentView x:Name="MentalHost" />
            </Border>

            <Label Text="PHYSICAL" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="2" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,10">
                <ContentView x:Name="PhysicalHost" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
