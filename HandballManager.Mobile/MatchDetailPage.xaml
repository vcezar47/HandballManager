<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HandballManager.Mobile"
             x:Class="HandballManager.Mobile.MatchDetailPage"
             Title="MATCH"
             BackgroundColor="#1A1A2E">

    <ContentPage.Resources>
        <local:TeamLogoSourceConverter x:Key="TeamLogo" />
        <local:RatingToColorConverter x:Key="RatingToColor" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="12">

            <!-- Scoreline -->
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,16">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="34,*,Auto,*,34" ColumnSpacing="8">
                        <Image Grid.Column="0" Source="{Binding Match.HomeTeamLogo, Converter={StaticResource TeamLogo}}" WidthRequest="30" HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding Match.HomeTeamName}" TextColor="#EAEAEA" FontFamily="OpenSansSemibold" FontSize="15" LineBreakMode="WordWrap" HorizontalTextAlignment="End" VerticalOptions="Center" />
                        <Label Grid.Column="2" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="24" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Match.HomeGoals}" />
                                    <Span Text=" – " />
                                    <Span Text="{Binding Match.AwayGoals}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Grid.Column="3" Text="{Binding Match.AwayTeamName}" TextColor="#EAEAEA" FontFamily="OpenSansSemibold" FontSize="15" LineBreakMode="WordWrap" VerticalOptions="Center" />
                        <Image Grid.Column="4" Source="{Binding Match.AwayTeamLogo, Converter={StaticResource TeamLogo}}" WidthRequest="30" HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center" />
                    </Grid>
                    <Label Text="{Binding Match.VenueName}" TextColor="#8888AA" FontSize="12" HorizontalOptions="Center" />
                    <Label Text="{Binding Match.Attendance, StringFormat='Attendance: {0:N0}'}" TextColor="#8888AA" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Player performances -->
            <Label Text="{Binding Match.HomeTeamName, StringFormat='{0} — PLAYERS'}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="1" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12,8">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,34,34,34,44" ColumnSpacing="4" Padding="0,4">
                        <Label Grid.Column="0" Text="PLAYER" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" />
                        <Label Grid.Column="1" Text="G" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="A" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="SV" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="4" Text="RAT" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#2A2A4A" />
                    <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding HomePlayerStats}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,34,34,34,44" ColumnSpacing="4" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding PlayerName}" TextColor="#EAEAEA" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Goals}" TextColor="#EAEAEA" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Assists}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="3" Text="{Binding Saves}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Border Grid.Column="4" BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColor}}" StrokeThickness="0" StrokeShape="RoundRectangle 6" Padding="5,3" HorizontalOptions="End" VerticalOptions="Center">
                                        <Label Text="{Binding Rating, StringFormat='{0:F1}'}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding Match.AwayTeamName, StringFormat='{0} — PLAYERS'}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="1" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12,8">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,34,34,34,44" ColumnSpacing="4" Padding="0,4">
                        <Label Grid.Column="0" Text="PLAYER" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" />
                        <Label Grid.Column="1" Text="G" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="A" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="SV" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="4" Text="RAT" TextColor="#A0A8C0" FontSize="9" FontFamily="OpenSansSemibold" HorizontalTextAlignment="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#2A2A4A" />
                    <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding AwayPlayerStats}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,34,34,34,44" ColumnSpacing="4" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding PlayerName}" TextColor="#EAEAEA" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Goals}" TextColor="#EAEAEA" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Assists}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="3" Text="{Binding Saves}" TextColor="#A0A8C0" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Border Grid.Column="4" BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColor}}" StrokeThickness="0" StrokeShape="RoundRectangle 6" Padding="5,3" HorizontalOptions="End" VerticalOptions="Center">
                                        <Label Text="{Binding Rating, StringFormat='{0:F1}'}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="12" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Goal-by-goal history -->
            <Label Text="SCORING" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="13" CharacterSpacing="2" />
            <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12,6">
                <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding ScoreHistory}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="44,*,64" Padding="0,7">
                                <Label Grid.Column="0" Text="{Binding Minute, StringFormat='{0}&#x2032;'}" TextColor="#8888AA" FontSize="13" />
                                <Label Grid.Column="1" Text="{Binding PlayerName}" TextColor="#EAEAEA" FontSize="13" LineBreakMode="TailTruncation" />
                                <Label Grid.Column="2" Text="{Binding ScoreText}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="13" HorizontalTextAlignment="End" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
