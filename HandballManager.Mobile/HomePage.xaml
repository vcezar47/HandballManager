<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HandballManager.Mobile"
             xmlns:controls="clr-namespace:HandballManager.Mobile.Controls"
             x:Class="HandballManager.Mobile.HomePage"
             Title="HOME"
             BackgroundColor="#1A1A2E">

    <ContentPage.Resources>
        <local:StringNotEmptyConverter x:Key="StringNotEmpty" />
        <local:TeamLogoSourceConverter x:Key="TeamLogo" />
        <local:BoolToDisabledOpacityConverter x:Key="BoolToDisabledOpacity" />
        <local:WindowUrgencyColorConverter x:Key="WindowUrgencyColor" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="16,10,16,0" RowSpacing="10">

        <!-- Date header + transfer window indicator -->
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label AutomationId="CurrentDateLabel" Text="{Binding CurrentDateText}" TextColor="#EAEAEA" FontFamily="OpenSansSemibold" FontSize="22" HorizontalOptions="Center" />

            <!-- Dot is a Border, not a BoxView: BoxView's CornerRadius leaves an opaque
                 square behind the circle on Android. -->
            <Border AutomationId="TransferWindowBadge" IsVisible="{Binding IsTransferWindowOpen}"
                    BackgroundColor="#16213E"
                    Stroke="{Binding TransferWindowUrgency, Converter={StaticResource WindowUrgencyColor}}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 14"
                    Padding="12,5" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="7">
                    <Border WidthRequest="8" HeightRequest="8" VerticalOptions="Center" StrokeThickness="0"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="{Binding TransferWindowUrgency, Converter={StaticResource WindowUrgencyColor}}" />
                    <Label Text="{Binding TransferWindowBadge}" FontSize="12" FontFamily="OpenSansSemibold" CharacterSpacing="0.5" VerticalOptions="Center"
                           TextColor="{Binding TransferWindowUrgency, Converter={StaticResource WindowUrgencyColor}}" />
                </HorizontalStackLayout>
            </Border>

            <!-- Why continuous advance came to a halt -->
            <Label AutomationId="AdvanceStoppedReason" Text="{Binding AutoAdvanceStoppedReason}" TextColor="#F0A500" FontSize="12" FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap"
                   IsVisible="{Binding AutoAdvanceStoppedReason, Converter={StaticResource StringNotEmpty}}" />
        </VerticalStackLayout>

        <!-- Next match card -->
        <Border Grid.Row="1" BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,12">
            <VerticalStackLayout Spacing="4">
                <Label Text="NEXT MATCH" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="2" />
                <Label Text="{Binding NextMatchInfo}" TextColor="#EAEAEA" FontSize="15" LineBreakMode="WordWrap" />
                <Label Text="{Binding NextMatchDateText}" TextColor="#8888AA" FontSize="12" />
                <Label Text="{Binding LastResultText}" TextColor="#8888AA" FontSize="13" Margin="0,4,0,0"
                       IsVisible="{Binding LastResultText, Converter={StaticResource StringNotEmpty}}" />
            </VerticalStackLayout>
        </Border>

        <!-- Season-over banner -->
        <Border Grid.Row="2" BackgroundColor="#16213E" Stroke="#F0A500" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,12"
                IsVisible="{Binding IsSeasonOver}">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="8">
                    <Image Source="trophy.png" WidthRequest="20" HeightRequest="20" Aspect="AspectFit" VerticalOptions="Center" />
                    <Label Text="SEASON COMPLETED" TextColor="#F0A500" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="2" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Label Text="{Binding SeasonCompletedMessage}" TextColor="#F0A500" FontSize="14" LineBreakMode="WordWrap" />
                <!-- Shown only once it works. It used to sit here looking live through the
                     whole of pre-season and do nothing when tapped. -->
                <Button Text="BEGIN NEW SEASON" AutomationId="BeginNewSeasonBtn"
                        BackgroundColor="#F0A500" TextColor="#1A1A2E" FontFamily="OpenSansSemibold" CornerRadius="10" HeightRequest="46"
                        Command="{Binding BeginNewSeasonCommand}" IsVisible="{Binding CanBeginNewSeason}" />
                <Label Text="{Binding NewSeasonUnlockText}" TextColor="#8888AA" FontSize="12" LineBreakMode="WordWrap"
                       IsVisible="{Binding IsAwaitingNewSeason}" />
            </VerticalStackLayout>
        </Border>

        <!-- Action buttons -->
        <Grid Grid.Row="3" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="8" ColumnSpacing="10">
            <Button Grid.Row="0" Grid.ColumnSpan="2" Text="PLAY MATCH" AutomationId="PlayMatchBtn"
                    BackgroundColor="#E94560" TextColor="White" FontFamily="OpenSansSemibold" CornerRadius="10" HeightRequest="50"
                    Command="{Binding NavigateToSquadSelectionCommand}" IsEnabled="{Binding CanSimulateMatch}"
                    Opacity="{Binding CanSimulateMatch, Converter={StaticResource BoolToDisabledOpacity}}" />
            <Button Grid.Row="1" Grid.Column="0" Text="INSTANT RESULT"
                    BackgroundColor="Transparent" TextColor="#EAEAEA" BorderColor="#3A5578" BorderWidth="1.5" FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="10" HeightRequest="46"
                    Command="{Binding SimulateMatchCommand}" IsEnabled="{Binding CanSimulateMatch}"
                    Opacity="{Binding CanSimulateMatch, Converter={StaticResource BoolToDisabledOpacity}}" />
            <!-- Advances continuously until something needs attention; the overlay's STOP
                 button is what interrupts it. -->
            <Button Grid.Row="1" Grid.Column="1" Text="ADVANCE" AutomationId="AdvanceBtn"
                    BackgroundColor="Transparent" TextColor="#EAEAEA" BorderColor="#3A5578" BorderWidth="1.5" FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="10" HeightRequest="46"
                    Command="{Binding StartAutoAdvanceCommand}" IsEnabled="{Binding CanAdvanceDay}"
                    Opacity="{Binding CanAdvanceDay, Converter={StaticResource BoolToDisabledOpacity}}" />
        </Grid>

        <!-- Matchweek results browser -->
        <Grid Grid.Row="4" RowDefinitions="Auto,*" RowSpacing="6">
            <Grid ColumnDefinitions="44,*,44">
                <Button Grid.Column="0" Text="‹" FontSize="20" BackgroundColor="#16213E" TextColor="#E94560" CornerRadius="8" HeightRequest="38"
                        Command="{Binding ChangeMatchweekCommand}" CommandParameter="-1" />
                <Label Grid.Column="1" Text="{Binding MatchweekDateText}" TextColor="#8888AA" FontSize="13" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="›" FontSize="20" BackgroundColor="#16213E" TextColor="#E94560" CornerRadius="8" HeightRequest="38"
                        Command="{Binding ChangeMatchweekCommand}" CommandParameter="1" />
            </Grid>

            <CollectionView Grid.Row="1" x:Name="ResultsView" ItemsSource="{Binding MatchweekResults}" SelectionMode="Single" SelectionChanged="OnResultSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#16213E" Stroke="#22304F" StrokeThickness="1" StrokeShape="RoundRectangle 8" Margin="0,3" Padding="10,9">
                            <Grid ColumnDefinitions="22,*,Auto,*,22" ColumnSpacing="6">
                                <Image Grid.Column="0" Source="{Binding HomeTeamLogo, Converter={StaticResource TeamLogo}}" WidthRequest="20" HeightRequest="20" Aspect="AspectFit" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding HomeTeamName}" TextColor="#EAEAEA" FontSize="13" LineBreakMode="TailTruncation" HorizontalTextAlignment="End" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding DashboardScoreDisplay}" TextColor="#E94560" FontFamily="OpenSansSemibold" FontSize="14" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding AwayTeamName}" TextColor="#EAEAEA" FontSize="13" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                <Image Grid.Column="4" Source="{Binding AwayTeamLogo, Converter={StaticResource TeamLogo}}" WidthRequest="20" HeightRequest="20" Aspect="AspectFit" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Busy overlay -->
        <Grid Grid.RowSpan="5" BackgroundColor="#AA1A1A2E" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#E94560" />
                <Label Text="Simulating…" TextColor="#8888AA" FontSize="13" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Continuous-advance overlay. Covers the screen so nothing else can be tapped
             while days are rolling, and turns STOP into a target you can't miss. The
             tab bar sits outside this page, so the code-behind hides it to match. -->
        <Grid Grid.RowSpan="5" BackgroundColor="#E01A1A2E" IsVisible="{Binding IsAutoAdvancing}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="16" Padding="32,0">
                <Label Text="ADVANCING" TextColor="#8888AA" FontFamily="OpenSansSemibold" FontSize="12" CharacterSpacing="3" HorizontalOptions="Center" />
                <Label Text="{Binding CurrentDateText}" TextColor="#EAEAEA" FontFamily="OpenSansSemibold" FontSize="20" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                <ActivityIndicator IsRunning="{Binding IsAutoAdvancing}" Color="#E94560" />
                <Button Text="STOP" AutomationId="StopAdvanceBtn"
                        BackgroundColor="#E94560" TextColor="White" FontFamily="OpenSansSemibold" FontSize="16" CharacterSpacing="2"
                        CornerRadius="12" HeightRequest="60" WidthRequest="200" HorizontalOptions="Center"
                        Command="{Binding StopAutoAdvanceCommand}" />
                <Label Text="Stops as soon as the current day finishes." TextColor="#666688" FontSize="11" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Season rollover. Takes a while — it ages every player in the game and clears
             a season of match data — so the wait is spelled out rather than looking like
             a freeze. No stop button: this one cannot be interrupted half-done. -->
        <Grid Grid.RowSpan="5" BackgroundColor="#F21A1A2E" IsVisible="{Binding IsRollingOverSeason}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="18" Padding="32,0">
                <ActivityIndicator IsRunning="{Binding IsRollingOverSeason}" Color="#F0A500"
                                   WidthRequest="56" HeightRequest="56" HorizontalOptions="Center" />
                <Label Text="PREPARING THE NEW SEASON" TextColor="#F0A500" FontFamily="OpenSansSemibold" FontSize="13"
                       CharacterSpacing="2" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                <Label Text="Crowning champions, ageing players and archiving the season's records. This can take a moment."
                       TextColor="#8888AA" FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Grid>

        <!-- Toasts sit above everything, including the overlays, so alerts raised
             mid-advance are still visible. -->
        <controls:ToastHost x:Name="Toasts" Grid.RowSpan="5" />

    </Grid>

</ContentPage>
