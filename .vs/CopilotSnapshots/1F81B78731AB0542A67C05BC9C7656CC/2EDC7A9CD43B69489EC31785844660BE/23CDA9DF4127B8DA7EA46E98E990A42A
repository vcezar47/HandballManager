<UserControl x:Class="HandballManager.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:HandballManager.Views"
             Background="#1A1A2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo/Header -->
        <StackPanel Grid.Row="0" Margin="0,40,0,30">
            <Image Source="/Assets/gamelogo/colorpng.png" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="HANDBALL" FontSize="32" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" FontFamily="Segoe UI"/>
            <TextBlock Text="MANAGER" FontSize="18" FontWeight="Bold" Foreground="#E94560"
                       HorizontalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <!-- Step 1: League Selection -->
            <views:LeagueSelectionView 
                Visibility="{Binding CurrentStep, Converter={StaticResource EqualityToVis}, ConverterParameter=1}"/>

            <!-- Step 2: Team Selection -->
            <views:TeamSelectionView 
                Visibility="{Binding CurrentStep, Converter={StaticResource EqualityToVis}, ConverterParameter=2}" Loaded="TeamSelectionView_Loaded"/>
        </Grid>

        <!-- Footer spacing -->
        <Border Grid.Row="2" Height="60"/>
    </Grid>
</UserControl>
