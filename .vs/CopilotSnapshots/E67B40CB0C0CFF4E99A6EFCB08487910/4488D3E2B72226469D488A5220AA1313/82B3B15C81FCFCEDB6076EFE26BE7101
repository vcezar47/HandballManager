<UserControl x:Class="HandballManager.Views.MatchDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#0F172A">
    <Grid Margin="20" MaxWidth="1000">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Score & Teams -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0" Content="← BACK" 
                        Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#334155" Foreground="White" FontWeight="Bold" Padding="12,6" 
                        Margin="0,0,20,0" VerticalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Home Logo Placeholder -->
                <Border Grid.Column="1" Width="60" Height="60" Background="#1A2238" CornerRadius="8" BorderBrush="#38BDF8" BorderThickness="2" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Center: Scores & Team Names -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="{Binding Match.Result}" FontSize="42" FontWeight="Black" Foreground="#38BDF8" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" Color="#38BDF8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                        <Run Text="{Binding Match.HomeTeamName}"/>
                        <Run Text=" vs " Foreground="#94A3B8"/>
                        <Run Text="{Binding Match.AwayTeamName}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Match.PlayedOn, StringFormat='{}{0:dd MMM yyyy}'}" Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Away Logo Placeholder -->
                <Border Grid.Column="3" Width="60" Height="60" Background="#1A2238" CornerRadius="8" BorderBrush="#E94560" BorderThickness="2" VerticalAlignment="Center">
                    <TextBlock Text="⚔️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Scorers Section -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Home Scorers -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Home Scorers" Foreground="#38BDF8" FontSize="11" FontWeight="ExtraBold" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                        <ItemsControl ItemsSource="{Binding HomeGoals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" MaxWidth="400"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A2238" CornerRadius="4" Padding="8,4" Margin="4" BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Foreground="White" FontSize="12">
                                            <Run Text="{Binding PlayerName}"/>
                                            <Run Text="{Binding Minute, StringFormat='({0}\')'}" Foreground="#38BDF8" FontWeight="Bold"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Away Scorers -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="Away Scorers" Foreground="#E94560" FontSize="11" FontWeight="ExtraBold" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                        <ItemsControl ItemsSource="{Binding AwayGoals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" MaxWidth="400"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A2238" CornerRadius="4" Padding="8,4" Margin="4" BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Foreground="White" FontSize="12">
                                            <Run Text="{Binding PlayerName}"/>
                                            <Run Text="{Binding Minute, StringFormat='({0}\')'}" Foreground="#E94560" FontWeight="Bold"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- Player Stats Section -->
                <Border Background="#1E293B" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="PLAYER PERFORMANCE" Foreground="#A0A8C0" FontWeight="ExtraBold" FontSize="11" Margin="5,0,0,20"/>
                        
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="Border" Background="#253248" CornerRadius="8,8,0,0" Padding="20,10" Margin="0,0,5,0">
                                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#38BDF8"/>
                                                        <Setter Property="Foreground" Value="#0F172A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="False">
                                                        <Setter Property="Foreground" Value="#A0A8C0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>

                                <!-- Home Team Tab -->
                                <TabItem Header="{Binding Match.HomeTeamName}">
                                    <Border Background="#1A2238" CornerRadius="0,8,8,8" Padding="15">
                                        <DataGrid ItemsSource="{Binding HomePlayerStats}" AutoGenerateColumns="False" 
                                                  Background="Transparent" BorderThickness="0" 
                                                  RowBackground="Transparent" AlternatingRowBackground="#1E273E"
                                                  Foreground="White" GridLinesVisibility="None" IsReadOnly="True"
                                                  CanUserAddRows="False" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="PLAYER" Binding="{Binding PlayerName}" Width="*"/>
                                                <DataGridTextColumn Header="GOALS" Binding="{Binding Goals}" Width="80"/>
                                                <DataGridTextColumn Header="ASSISTS" Binding="{Binding Assists}" Width="80"/>
                                                <DataGridTextColumn Header="SAVES" Binding="{Binding Saves}" Width="80"/>
                                                <DataGridTemplateColumn Header="RATING" Width="100">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#38BDF8" CornerRadius="4" HorizontalAlignment="Left" Padding="6,2" Margin="4">
                                                                <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}" Foreground="#0F172A" FontWeight="Bold"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </TabItem>

                                <!-- Away Team Tab -->
                                <TabItem Header="{Binding Match.AwayTeamName}">
                                    <Border Background="#1A2238" CornerRadius="0,8,8,8" Padding="15">
                                        <DataGrid ItemsSource="{Binding AwayPlayerStats}" AutoGenerateColumns="False" 
                                                  Background="Transparent" BorderThickness="0" 
                                                  RowBackground="Transparent" AlternatingRowBackground="#1E273E"
                                                  Foreground="White" GridLinesVisibility="None" IsReadOnly="True"
                                                  CanUserAddRows="False" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="PLAYER" Binding="{Binding PlayerName}" Width="*"/>
                                                <DataGridTextColumn Header="GOALS" Binding="{Binding Goals}" Width="80"/>
                                                <DataGridTextColumn Header="ASSISTS" Binding="{Binding Assists}" Width="80"/>
                                                <DataGridTextColumn Header="SAVES" Binding="{Binding Saves}" Width="80"/>
                                                <DataGridTemplateColumn Header="RATING" Width="100">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#E94560" CornerRadius="4" HorizontalAlignment="Left" Padding="6,2" Margin="4">
                                                                <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}" Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </UserControl>
