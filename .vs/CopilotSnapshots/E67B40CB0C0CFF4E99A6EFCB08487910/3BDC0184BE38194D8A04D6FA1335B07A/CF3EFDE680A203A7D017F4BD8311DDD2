<UserControl x:Class="HandballManager.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1100"
             Background="#1A1A2E">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <!-- Logo Section -->
            <StackPanel Margin="0,0,0,60" VerticalAlignment="Center">
                <TextBlock Text="🤾" FontSize="96" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="HANDBALL" FontSize="48" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                <TextBlock Text="MANAGER" FontSize="32" FontWeight="Bold" Foreground="#E94560"
                           HorizontalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,0,20"/>
                <TextBlock Text="v0.1.0 Alpha" FontSize="12" Foreground="#94A3B8"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Menu Buttons -->
            <StackPanel Spacing="16">
                <!-- Start Game Button -->
                <Button Command="{Binding StartGameCommand}" 
                        Height="60" 
                        Background="#38BDF8" 
                        Foreground="#0F172A" 
                        FontSize="18" 
                        FontWeight="Bold"
                        FontFamily="Segoe UI"
                        Cursor="Hand"
                        Content="START GAME">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#0EA5E9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#0284C7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Quit Game Button -->
                <Button Command="{Binding QuitGameCommand}" 
                        Height="60" 
                        Background="#334155" 
                        Foreground="White" 
                        FontSize="18" 
                        FontWeight="Bold"
                        FontFamily="Segoe UI"
                        Cursor="Hand"
                        Content="QUIT GAME">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#475569"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#1E293B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
